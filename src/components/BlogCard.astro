---
export interface Props {
  title: string;
  description: string;
  href: string;
  date: string;
  category: string;
  readTime?: string;
}

const { title, description, href, date, category, readTime = '5 min read' } = Astro.props;
---

<a href={href} class="group block bg-white rounded-xl border border-ebony/8 shadow-sm hover:shadow-lg transition-all duration-200 overflow-hidden">
  <div class="h-2 bg-gradient-to-r from-saffron-400 to-burgundy-600 group-hover:from-saffron-300 group-hover:to-burgundy-500 transition-all"></div>
  <div class="p-5">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs font-semibold text-saffron-600 bg-saffron-50 px-2 py-0.5 rounded-full">{category}</span>
      <span class="text-xs text-ebony/40">{readTime}</span>
    </div>
    <h3 class="font-display font-bold text-ebony text-base mb-2 leading-snug group-hover:text-burgundy-700 transition-colors line-clamp-2">{title}</h3>
    <p class="text-sm text-ebony/60 leading-relaxed line-clamp-2 mb-4">{description}</p>
    <div class="flex items-center justify-between">
      <span class="text-xs text-ebony/40">{date}</span>
      <span class="text-xs font-semibold text-saffron-600 flex items-center gap-1 group-hover:gap-2 transition-all">
        Read
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </div>
  </div>
</a>
