---
export interface Props {
  title: string; description: string; href: string;
  level: 'beginner'|'intermediate'|'advanced'|'practice';
  duration?: string; icon?: string;
}
const {title,description,href,level,duration='15 min',icon='🎵'} = Astro.props;
const cfg = {
  beginner:     {badge:'badge-beginner',    label:'Beginner',     border:'border-green-200',  bg:'hover:bg-green-50'},
  intermediate: {badge:'badge-intermediate',label:'Intermediate', border:'border-yellow-200', bg:'hover:bg-yellow-50'},
  advanced:     {badge:'badge-advanced',    label:'Advanced',     border:'border-red-200',    bg:'hover:bg-red-50'},
  practice:     {badge:'badge-practice',    label:'Practice',     border:'border-amber-200',  bg:'hover:bg-amber-50'},
}[level];
---
<a href={href}
   class={`lesson-card flex flex-col bg-white rounded-2xl border ${cfg.border} ${cfg.bg} p-4 sm:p-5 transition-all`}
   style="text-decoration:none">
  <div class="flex items-start justify-between mb-3 gap-2">
    <span class="text-2xl sm:text-3xl flex-shrink-0">{icon}</span>
    <div class="flex items-center gap-2 flex-wrap justify-end">
      <span class={`badge ${cfg.badge}`}>{cfg.label}</span>
      <span class="text-xs" style="color:rgba(28,16,8,.4);font-family:'Plus Jakarta Sans',sans-serif">⏱ {duration}</span>
    </div>
  </div>
  <h3 class="font-sans font-bold text-sm sm:text-base mb-1.5 leading-snug" style="color:#1c1008;font-family:'Plus Jakarta Sans',sans-serif">{title}</h3>
  <p class="text-xs sm:text-sm flex-1 mb-3 leading-relaxed" style="color:rgba(28,16,8,.6);font-family:'Plus Jakarta Sans',sans-serif">{description}</p>
  <div class="flex items-center gap-1 text-xs font-bold" style={`color:${level==='beginner'?'#166534':level==='intermediate'?'#854d0e':level==='advanced'?'#991b1b':'#92400e'};font-family:'Plus Jakarta Sans',sans-serif`}>
    Start Lesson
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
  </div>
</a>
