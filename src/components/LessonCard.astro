---
export interface Props {
  title: string;
  description: string;
  href: string;
  level: 'beginner' | 'intermediate' | 'advanced' | 'practice';
  duration?: string;
  icon?: string;
}

const { title, description, href, level, duration = '15 min', icon = '🎵' } = Astro.props;

const levelConfig = {
  beginner: { color: 'text-green-400', bg: 'bg-green-500/10 border-green-500/20', badge: 'Beginner', badgeBg: 'bg-green-500/20 text-green-400' },
  intermediate: { color: 'text-saffron-400', bg: 'bg-saffron-500/10 border-saffron-500/20', badge: 'Intermediate', badgeBg: 'bg-saffron-500/20 text-saffron-400' },
  advanced: { color: 'text-burgundy-400', bg: 'bg-burgundy-500/10 border-burgundy-500/20', badge: 'Advanced', badgeBg: 'bg-burgundy-500/20 text-burgundy-300' },
  practice: { color: 'text-gold-400', bg: 'bg-gold-500/10 border-gold-500/20', badge: 'Practice', badgeBg: 'bg-gold-500/20 text-gold-500' },
};

const config = levelConfig[level];
---

<a href={href} class={`lesson-card block rounded-xl border p-5 hover:bg-ebony/5 transition-all ${config.bg}`}>
  <div class="flex items-start justify-between mb-3">
    <span class="text-2xl">{icon}</span>
    <div class="flex items-center gap-2">
      <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${config.badgeBg}`}>{config.badge}</span>
      <span class="text-xs text-ebony/40">⏱ {duration}</span>
    </div>
  </div>
  <h3 class="font-display font-bold text-ebony text-base mb-2 leading-tight">{title}</h3>
  <p class="text-sm text-ebony/60 leading-relaxed">{description}</p>
  <div class={`mt-3 flex items-center gap-1 text-xs font-semibold ${config.color}`}>
    <span>Start Lesson</span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
  </div>
</a>
