---
// No props needed
---

<div class="hm-widget" id="hm-root" aria-label="Web Harmonium Instrument">

  <!-- Top bar -->
  <div class="flex items-center justify-between mb-2 flex-wrap gap-2">
    <div class="flex items-center gap-2">
      <div class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0"
           style="background:linear-gradient(135deg,#d4920a,#c8360a)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="white"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
      </div>
      <div class="leading-tight">
        <p class="text-xs font-bold" style="color:#f0aa0e;font-family:'Plus Jakarta Sans',sans-serif">Harmonium Halt</p>
        <p class="text-xs" style="color:rgba(250,246,239,.4);font-family:'JetBrains Mono',monospace">Web Harmonium v3</p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <div class="hm-note-badge" id="hm-note-display">—</div>
      <div class="hm-note-badge" id="hm-oct-display">Oct 4</div>
    </div>
  </div>

  <!-- Bellows -->
  <div class="hm-bellows" id="hm-bellows" role="button" aria-label="Tap to activate sound"></div>

  <!-- Keyboard -->
  <div class="hm-keyboard-outer" role="group" aria-label="Harmonium keyboard">
    <div class="hm-keyboard" id="hm-keyboard"></div>
  </div>

  <!-- Controls -->
  <div class="hm-controls">
    <!-- Volume -->
    <div class="flex items-center gap-1.5">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(250,246,239,.5)" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
      <input type="range" id="hm-vol" class="hm-vol" min="0" max="100" value="75" aria-label="Volume"/>
    </div>

    <!-- Octave -->
    <div class="flex items-center gap-1">
      <span class="text-xs" style="color:rgba(250,246,239,.45);font-family:'Plus Jakarta Sans',sans-serif">Oct</span>
      <button class="hm-btn" id="hm-oct-dn" aria-label="Octave down">−</button>
      <button class="hm-btn" id="hm-oct-up" aria-label="Octave up">+</button>
    </div>

    <!-- Notation toggle -->
    <div class="flex items-center gap-1 rounded-lg p-0.5" style="background:rgba(0,0,0,.25)">
      <button class="hm-btn active" id="btn-indian" aria-pressed="true">सा रे ग</button>
      <button class="hm-btn"        id="btn-western" aria-pressed="false">C D E</button>
    </div>

    <!-- Sound on/off -->
    <button class="hm-btn" id="hm-sound-btn" style="color:#4ade80;border-color:rgba(74,222,128,.3)">
      <span style="width:7px;height:7px;border-radius:50%;background:#4ade80;display:inline-block;animation:pulse 1.5s infinite"></span>
      Sound ON
    </button>
  </div>

  <!-- Shortcut hint -->
  <p class="mt-2 text-center" style="font-size:10px;color:rgba(250,246,239,.3);font-family:'JetBrains Mono',monospace">
    Keys: A S D F G H J K (white) &nbsp;|&nbsp; W E T Y U (black) &nbsp;|&nbsp; ←→ octave
  </p>
</div>

<style>
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
</style>

<script>
(function(){
/* ── Note table ── */
const NOTES = [
  {id:'C',  t:'w', ind:'सा',        wes:'C',  f:261.63, k:'a'},
  {id:'Cs', t:'b', ind:'क॰रे',       wes:'C#', f:277.18, k:'w'},
  {id:'D',  t:'w', ind:'रे',         wes:'D',  f:293.66, k:'s'},
  {id:'Ds', t:'b', ind:'क॰ग',        wes:'D#', f:311.13, k:'e'},
  {id:'E',  t:'w', ind:'ग',          wes:'E',  f:329.63, k:'d'},
  {id:'F',  t:'w', ind:'म',          wes:'F',  f:349.23, k:'f'},
  {id:'Fs', t:'b', ind:'ति॰म',       wes:'F#', f:369.99, k:'t'},
  {id:'G',  t:'w', ind:'प',          wes:'G',  f:392.00, k:'g'},
  {id:'Gs', t:'b', ind:'क॰ध',        wes:'G#', f:415.30, k:'y'},
  {id:'A',  t:'w', ind:'ध',          wes:'A',  f:440.00, k:'h'},
  {id:'As', t:'b', ind:'क॰नि',       wes:'A#', f:466.16, k:'u'},
  {id:'B',  t:'w', ind:'नि',         wes:'B',  f:493.88, k:'j'},
  {id:'C2', t:'w', ind:'सा॒',        wes:'C',  f:523.25, k:'k'},
  {id:'Cs2',t:'b', ind:'क॰रे॒',      wes:'C#', f:554.37, k:'o'},
  {id:'D2', t:'w', ind:'रे॒',        wes:'D',  f:587.33, k:'l'},
  {id:'Ds2',t:'b', ind:'क॰ग॒',       wes:'D#', f:622.25, k:'p'},
  {id:'E2', t:'w', ind:'ग॒',         wes:'E',  f:659.25, k:';'},
  {id:'F2', t:'w', ind:'म॒',         wes:'F',  f:698.46, k:"'"},
  {id:'Fs2',t:'b', ind:'ति॰म॒',      wes:'F#', f:739.99, k:']'},
  {id:'G2', t:'w', ind:'प॒',         wes:'G',  f:784.00, k:'\\'},
];

const BLACK_POSITIONS = [
  {id:'Cs', after:0},{id:'Ds',after:1},{id:'Fs',after:3},
  {id:'Gs', after:4},{id:'As',after:5},
  {id:'Cs2',after:7},{id:'Ds2',after:8},{id:'Fs2',after:10},
];

/* ── State ── */
let ctx = null, masterGain = null;
let soundOn = true, octave = 4, notation = 'indian';
const active = new Map(); // noteId → {o1,o2,g,f}
const held   = new Set();

/* ── Audio ── */
function initCtx(){
  if(ctx) return;
  try{
    ctx = new(window.AudioContext||window.webkitAudioContext)();
    masterGain = ctx.createGain();
    masterGain.gain.value = 0.75;

    // Reverb
    const rev = ctx.createConvolver();
    const buf = ctx.createBuffer(2, ctx.sampleRate*1.2, ctx.sampleRate);
    for(let c=0;c<2;c++){
      const d=buf.getChannelData(c);
      for(let i=0;i<d.length;i++) d[i]=(Math.random()*2-1)*Math.pow(1-i/d.length,2.2);
    }
    rev.buffer = buf;
    const rg = ctx.createGain(); rg.gain.value = 0.14;
    masterGain.connect(ctx.destination);
    masterGain.connect(rg); rg.connect(rev); rev.connect(ctx.destination);
  }catch(e){console.warn('AudioContext failed',e);}
}

function freq(noteId){
  const n = NOTES.find(x=>x.id===noteId); if(!n) return 440;
  return n.f * Math.pow(2, octave-4);
}

function playNote(id){
  if(!soundOn||active.has(id)) return;
  initCtx(); if(!ctx||!masterGain) return;
  if(ctx.state==='suspended') ctx.resume();
  const hz = freq(id), now = ctx.currentTime;
  const o1=ctx.createOscillator(), o2=ctx.createOscillator();
  const g=ctx.createGain(), f=ctx.createBiquadFilter();
  o1.type='sawtooth'; o2.type='sawtooth';
  o1.frequency.value=hz; o2.frequency.value=hz*1.004;
  f.type='lowpass'; f.frequency.value=1600; f.Q.value=1.2;
  g.gain.setValueAtTime(0,now);
  g.gain.linearRampToValueAtTime(0.38,now+0.03);
  g.gain.linearRampToValueAtTime(0.32,now+0.18);
  o1.connect(f); o2.connect(f); f.connect(g); g.connect(masterGain);
  o1.start(now); o2.start(now);
  active.set(id,{o1,o2,g,f});
}

function stopNote(id){
  if(!ctx||!active.has(id)) return;
  const {o1,o2,g}=active.get(id); const now=ctx.currentTime;
  g.gain.cancelScheduledValues(now);
  g.gain.setValueAtTime(g.gain.value,now);
  g.gain.exponentialRampToValueAtTime(0.0001,now+0.45);
  setTimeout(()=>{try{o1.stop();o2.stop();}catch{}},500);
  active.delete(id);
}

/* ── Keyboard render ── */
function getLabel(note){
  return notation==='indian' ? note.ind : note.wes;
}

function renderKeys(){
  const kb = document.getElementById('hm-keyboard'); if(!kb) return;
  kb.innerHTML='';

  const whites = NOTES.filter(n=>n.t==='w');
  const wEls = [];

  whites.forEach(note=>{
    const el=document.createElement('div');
    el.className='hm-wk'; el.dataset.id=note.id;
    el.setAttribute('role','button'); el.setAttribute('tabindex','0');
    el.setAttribute('aria-label',getLabel(note));

    const lbl=document.createElement('span');
    lbl.className='key-label'; lbl.textContent=getLabel(note);
    el.appendChild(lbl);

    if(note.k){
      const kl=document.createElement('span');
      kl.className='key-kbd'; kl.textContent=note.k.toUpperCase();
      el.appendChild(kl);
    }
    bind(el,note.id);
    kb.appendChild(el);
    wEls.push(el);
  });

  // Position black keys after layout
  requestAnimationFrame(()=>{
    const kbRect = kb.getBoundingClientRect();
    BLACK_POSITIONS.forEach(({id,after})=>{
      const note=NOTES.find(n=>n.id===id); if(!note) return;
      const lw=wEls[after], rw=wEls[after+1];
      if(!lw||!rw) return;
      const lR=lw.getBoundingClientRect(), rR=rw.getBoundingClientRect();
      const cx=(lR.right+rR.left)/2 - kbRect.left;

      const bk=document.createElement('div');
      bk.className='hm-bk'; bk.dataset.id=id;
      bk.setAttribute('role','button'); bk.setAttribute('tabindex','0');
      bk.setAttribute('aria-label',getLabel(note));
      bk.style.left=(cx-13)+'px';

      const lbl=document.createElement('span');
      lbl.className='key-label'; lbl.textContent=note.wes;
      bk.appendChild(lbl);

      bind(bk,id);
      kb.appendChild(bk);
    });
  });
}

function bind(el,id){
  // Mouse
  el.addEventListener('mousedown',e=>{e.preventDefault();startNote(id,el);});
  el.addEventListener('mouseup',  ()=>endNote(id,el));
  el.addEventListener('mouseleave',()=>endNote(id,el));
  // Touch
  el.addEventListener('touchstart',e=>{e.preventDefault();startNote(id,el);},{passive:false});
  el.addEventListener('touchend',  e=>{e.preventDefault();endNote(id,el);});
  el.addEventListener('touchcancel',()=>endNote(id,el));
}

function startNote(id,el){
  el.classList.add('on');
  playNote(id);
  const n=NOTES.find(x=>x.id===id);
  const disp=document.getElementById('hm-note-display');
  if(disp&&n) disp.textContent=getLabel(n);
}
function endNote(id,el){
  el.classList.remove('on');
  stopNote(id);
}

/* ── Keyboard shortcuts ── */
const kmap={};
NOTES.forEach(n=>{if(n.k) kmap[n.k]=n.id;});

document.addEventListener('keydown',e=>{
  if(e.repeat) return;
  const k=e.key.toLowerCase();
  if(k==='arrowleft'){changeOct(-1);return;}
  if(k==='arrowright'){changeOct(1);return;}
  const id=kmap[k];
  if(id&&!held.has(k)){
    held.add(k);
    const el=document.querySelector(`[data-id="${id}"]`);
    if(el) startNote(id,el);
  }
});
document.addEventListener('keyup',e=>{
  const k=e.key.toLowerCase();
  const id=kmap[k];
  if(id){
    held.delete(k);
    const el=document.querySelector(`[data-id="${id}"]`);
    if(el) endNote(id,el);
  }
});

/* ── Controls ── */
function changeOct(d){
  octave=Math.max(2,Math.min(6,octave+d));
  const disp=document.getElementById('hm-oct-display');
  if(disp) disp.textContent='Oct '+octave;
}

document.getElementById('hm-oct-dn')?.addEventListener('click',()=>changeOct(-1));
document.getElementById('hm-oct-up')?.addEventListener('click',()=>changeOct(1));

document.getElementById('hm-vol')?.addEventListener('input',e=>{
  if(masterGain) masterGain.gain.value=parseFloat(e.target.value)/100;
});

document.getElementById('hm-sound-btn')?.addEventListener('click',function(){
  soundOn=!soundOn;
  [...active.keys()].forEach(id=>{
    const el=document.querySelector(`[data-id="${id}"]`);
    if(el) endNote(id,el);
  });
  if(soundOn){
    this.innerHTML='<span style="width:7px;height:7px;border-radius:50%;background:#4ade80;display:inline-block;animation:pulse 1.5s infinite"></span> Sound ON';
    this.style.color='#4ade80'; this.style.borderColor='rgba(74,222,128,.3)';
  } else {
    this.innerHTML='<span style="width:7px;height:7px;border-radius:50%;background:#f87171;display:inline-block"></span> Sound OFF';
    this.style.color='#f87171'; this.style.borderColor='rgba(248,113,113,.3)';
  }
});

document.getElementById('btn-indian')?.addEventListener('click',function(){
  notation='indian';
  this.classList.add('active');
  document.getElementById('btn-western')?.classList.remove('active');
  renderKeys();
});
document.getElementById('btn-western')?.addEventListener('click',function(){
  notation='western';
  this.classList.add('active');
  document.getElementById('btn-indian')?.classList.remove('active');
  renderKeys();
});

document.getElementById('hm-bellows')?.addEventListener('click',()=>{
  initCtx();
  if(ctx?.state==='suspended') ctx.resume();
});

/* ── Init ── */
renderKeys();
})();
</script>
