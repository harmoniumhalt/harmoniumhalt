---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<div class="harmonium-widget" id="harmonium-widget">
  <!-- Decorative top panel -->
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-gold-400 to-saffron-600 flex items-center justify-center shadow-md">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
      </div>
      <div>
        <h3 class="font-display font-bold text-gold-400 text-sm leading-tight">Harmonium Halt</h3>
        <p class="text-ivory/50 text-xs">Web Harmonium v2.0</p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <span id="octave-display" class="bg-black/30 text-gold-400 text-xs font-mono px-2 py-1 rounded border border-gold-500/30">Oct: 4</span>
      <span id="note-display" class="bg-black/30 text-saffron-400 text-xs font-mono px-2 py-1 rounded border border-saffron-500/30 min-w-[50px] text-center">—</span>
    </div>
  </div>

  <!-- Bellows -->
  <div class="bellows-section mb-3 cursor-pointer select-none" id="bellows" title="Click to toggle sound">
    <div class="bellows-fold"></div>
    <span class="relative z-10 text-xs font-medium text-white/60 tracking-widest uppercase">
      ♦ BELLOWS ♦
    </span>
  </div>

  <!-- Main Keyboard -->
  <div class="harmonium-container">
    <div class="keys-wrapper" id="keyboard" role="group" aria-label="Harmonium keyboard">
    </div>
  </div>

  <!-- Controls -->
  <div class="flex flex-wrap items-center justify-between gap-3 mt-4">
    <!-- Volume -->
    <div class="flex items-center gap-2">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ivory/60"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
      <input
        type="range"
        id="volume-slider"
        min="0"
        max="100"
        value="75"
        class="w-24 h-1.5 rounded-full appearance-none bg-white/20 cursor-pointer accent-saffron-500"
        aria-label="Volume"
      />
    </div>

    <!-- Octave Controls -->
    <div class="flex items-center gap-2">
      <span class="text-xs text-ivory/50">Octave</span>
      <button id="oct-down" class="w-7 h-7 rounded-md bg-white/10 hover:bg-saffron-500/30 border border-white/10 text-ivory/80 text-sm font-bold transition-colors" aria-label="Octave down">−</button>
      <button id="oct-up" class="w-7 h-7 rounded-md bg-white/10 hover:bg-saffron-500/30 border border-white/10 text-ivory/80 text-sm font-bold transition-colors" aria-label="Octave up">+</button>
    </div>

    <!-- Note System Toggle -->
    <div class="flex items-center gap-1.5 bg-black/20 rounded-lg p-1">
      <button id="btn-indian" class="px-2.5 py-1 rounded-md text-xs font-semibold transition-all bg-saffron-500 text-white">सा रे ग</button>
      <button id="btn-western" class="px-2.5 py-1 rounded-md text-xs font-semibold transition-all text-ivory/60 hover:text-ivory">C D E</button>
    </div>

    <!-- Sound Toggle -->
    <button
      id="sound-toggle"
      class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-green-500/20 border border-green-500/30 text-green-400 text-xs font-semibold hover:bg-green-500/30 transition-colors"
    >
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      Sound ON
    </button>
  </div>

  <!-- Keyboard Shortcuts Guide -->
  <div class="mt-3 p-2.5 bg-black/20 rounded-lg border border-white/5">
    <p class="text-xs text-ivory/40 text-center">
      <span class="text-ivory/60 font-medium">Keyboard:</span>
      A S D F G H J K L (white keys) &nbsp;|&nbsp; W E T Y U (black keys) &nbsp;|&nbsp; ← → (octave)
    </p>
  </div>
</div>

<script>
(function() {
  // ─── Note Definitions ─────────────────────────────────────────────────
  const NOTES = [
    { id: 'C',  type: 'white', indian: 'सा', western: 'C',  freq_base: 261.63, shortcut: 'a' },
    { id: 'Cs', type: 'black', indian: 'कोमल रे', western: 'C#', freq_base: 277.18, shortcut: 'w' },
    { id: 'D',  type: 'white', indian: 'रे', western: 'D',  freq_base: 293.66, shortcut: 's' },
    { id: 'Ds', type: 'black', indian: 'कोमल ग', western: 'D#', freq_base: 311.13, shortcut: 'e' },
    { id: 'E',  type: 'white', indian: 'ग',  western: 'E',  freq_base: 329.63, shortcut: 'd' },
    { id: 'F',  type: 'white', indian: 'म',  western: 'F',  freq_base: 349.23, shortcut: 'f' },
    { id: 'Fs', type: 'black', indian: 'तीव्र म', western: 'F#', freq_base: 369.99, shortcut: 't' },
    { id: 'G',  type: 'white', indian: 'प',  western: 'G',  freq_base: 392.00, shortcut: 'g' },
    { id: 'Gs', type: 'black', indian: 'कोमल ध', western: 'G#', freq_base: 415.30, shortcut: 'y' },
    { id: 'A',  type: 'white', indian: 'ध',  western: 'A',  freq_base: 440.00, shortcut: 'h' },
    { id: 'As', type: 'black', indian: 'कोमल नि', western: 'A#', freq_base: 466.16, shortcut: 'u' },
    { id: 'B',  type: 'white', indian: 'नि', western: 'B',  freq_base: 493.88, shortcut: 'j' },
    // Octave 2
    { id: 'C2', type: 'white', indian: 'सा॒', western: 'C', freq_base: 523.25, shortcut: 'k' },
    { id: 'Cs2',type: 'black', indian: 'क रे॒', western: 'C#', freq_base: 554.37, shortcut: 'o' },
    { id: 'D2', type: 'white', indian: 'रे॒', western: 'D', freq_base: 587.33, shortcut: 'l' },
    { id: 'Ds2',type: 'black', indian: 'क ग॒', western: 'D#', freq_base: 622.25, shortcut: 'p' },
    { id: 'E2', type: 'white', indian: 'ग॒',  western: 'E', freq_base: 659.25, shortcut: ';' },
    { id: 'F2', type: 'white', indian: 'म॒',  western: 'F', freq_base: 698.46, shortcut: "'" },
    { id: 'Fs2',type: 'black', indian: 'त म॒', western: 'F#',freq_base: 739.99, shortcut: ']' },
    { id: 'G2', type: 'white', indian: 'प॒',  western: 'G', freq_base: 784.00, shortcut: '\\' },
  ];

  // ─── Audio Engine ─────────────────────────────────────────────────────
  let audioCtx = null;
  let masterGain = null;
  let reverbNode = null;
  let soundEnabled = true;
  let currentOctave = 4;
  let noteSystem = 'indian';
  const activeNodes = new Map();

  function initAudio() {
    if (audioCtx) return;
    try {
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      masterGain = audioCtx.createGain();
      masterGain.gain.value = 0.75;

      // Convolver for reverb
      reverbNode = audioCtx.createConvolver();
      const reverbBuffer = audioCtx.createBuffer(2, audioCtx.sampleRate * 1.5, audioCtx.sampleRate);
      for (let ch = 0; ch < 2; ch++) {
        const data = reverbBuffer.getChannelData(ch);
        for (let i = 0; i < data.length; i++) {
          data[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / data.length, 2);
        }
      }
      reverbNode.buffer = reverbBuffer;

      const reverbGain = audioCtx.createGain();
      reverbGain.gain.value = 0.18;

      masterGain.connect(audioCtx.destination);
      masterGain.connect(reverbGain);
      reverbGain.connect(reverbNode);
      reverbNode.connect(audioCtx.destination);
    } catch (e) {
      console.warn('Web Audio API not supported:', e);
    }
  }

  function getFrequency(noteId) {
    const note = NOTES.find(n => n.id === noteId);
    if (!note) return 440;
    const octaveShift = currentOctave - 4;
    return note.freq_base * Math.pow(2, octaveShift);
  }

  function playNote(noteId) {
    if (!soundEnabled) return;
    initAudio();
    if (!audioCtx || !masterGain) return;

    if (audioCtx.state === 'suspended') {
      audioCtx.resume();
    }

    if (activeNodes.has(noteId)) return;

    const freq = getFrequency(noteId);
    const now = audioCtx.currentTime;

    // Harmonium = sawtooth with slight detuning (reed-like)
    const osc1 = audioCtx.createOscillator();
    const osc2 = audioCtx.createOscillator();
    const gainNode = audioCtx.createGain();

    osc1.type = 'sawtooth';
    osc2.type = 'sawtooth';
    osc1.frequency.value = freq;
    osc2.frequency.value = freq * 1.003; // slight detune for richness

    // Attack-sustain envelope (bellows-like)
    gainNode.gain.setValueAtTime(0, now);
    gainNode.gain.linearRampToValueAtTime(0.4, now + 0.03);
    gainNode.gain.linearRampToValueAtTime(0.35, now + 0.15);

    // Low pass filter (warm harmonium tone)
    const filter = audioCtx.createBiquadFilter();
    filter.type = 'lowpass';
    filter.frequency.value = 1800;
    filter.Q.value = 1.5;

    osc1.connect(filter);
    osc2.connect(filter);
    filter.connect(gainNode);
    gainNode.connect(masterGain);

    osc1.start(now);
    osc2.start(now);

    activeNodes.set(noteId, { osc1, osc2, gainNode, filter });
  }

  function stopNote(noteId) {
    if (!audioCtx || !activeNodes.has(noteId)) return;
    const { osc1, osc2, gainNode } = activeNodes.get(noteId);
    const now = audioCtx.currentTime;

    gainNode.gain.cancelScheduledValues(now);
    gainNode.gain.setValueAtTime(gainNode.gain.value, now);
    gainNode.gain.exponentialRampToValueAtTime(0.001, now + 0.4);

    setTimeout(() => {
      try { osc1.stop(); osc2.stop(); } catch {}
    }, 450);

    activeNodes.delete(noteId);
  }

  // ─── Keyboard Rendering ───────────────────────────────────────────────
  function renderKeyboard() {
    const keyboard = document.getElementById('keyboard');
    if (!keyboard) return;
    keyboard.innerHTML = '';

    // We need to place black keys over white keys
    const whiteNotes = NOTES.filter(n => n.type === 'white');
    const allNotes = NOTES;

    // Create a wrapper for proper positioning
    const wrapper = document.createElement('div');
    wrapper.style.cssText = 'position: relative; display: flex; gap: 2px; height: 140px; flex: 1;';

    let whiteIdx = 0;
    const whiteKeyEls = [];

    // First pass: white keys
    whiteNotes.forEach((note) => {
      const key = document.createElement('div');
      key.className = 'white-key';
      key.dataset.noteId = note.id;
      key.setAttribute('role', 'button');
      key.setAttribute('aria-label', `${noteSystem === 'indian' ? note.indian : note.western} note`);
      key.setAttribute('tabindex', '0');

      const labelEl = document.createElement('span');
      labelEl.className = noteSystem === 'indian' ? 'key-label indian' : 'key-label';
      labelEl.textContent = noteSystem === 'indian' ? note.indian : note.western;
      labelEl.style.cssText = 'pointer-events: none; font-size: 8px; line-height: 1.1; text-align: center; padding: 0 2px;';
      key.appendChild(labelEl);

      if (note.shortcut) {
        const shortcutEl = document.createElement('span');
        shortcutEl.className = 'key-label';
        shortcutEl.textContent = note.shortcut.toUpperCase();
        shortcutEl.style.cssText = 'pointer-events: none; font-size: 7px; color: rgba(0,0,0,0.3); font-family: monospace;';
        key.appendChild(shortcutEl);
      }

      wrapper.appendChild(key);
      whiteKeyEls.push({ el: key, note, idx: whiteIdx });
      whiteIdx++;
    });

    keyboard.appendChild(wrapper);

    // Second pass: black keys (positioned absolutely)
    // Map: after which white key index does this black key appear
    const blackKeyPositions = [
      { noteId: 'Cs',  afterWhite: 0 },
      { noteId: 'Ds',  afterWhite: 1 },
      { noteId: 'Fs',  afterWhite: 3 },
      { noteId: 'Gs',  afterWhite: 4 },
      { noteId: 'As',  afterWhite: 5 },
      { noteId: 'Cs2', afterWhite: 7 },
      { noteId: 'Ds2', afterWhite: 8 },
      { noteId: 'Fs2', afterWhite: 10 },
    ];

    // Wait for layout, then position black keys
    requestAnimationFrame(() => {
      blackKeyPositions.forEach(({ noteId, afterWhite }) => {
        const note = NOTES.find(n => n.id === noteId);
        if (!note) return;

        const leftWhite = whiteKeyEls[afterWhite];
        const rightWhite = whiteKeyEls[afterWhite + 1];
        if (!leftWhite || !rightWhite) return;

        const leftRect = leftWhite.el.getBoundingClientRect();
        const rightRect = rightWhite.el.getBoundingClientRect();
        const wrapperRect = wrapper.getBoundingClientRect();

        const centerX = (leftRect.right + rightRect.left) / 2 - wrapperRect.left;

        const blackKey = document.createElement('div');
        blackKey.className = 'black-key';
        blackKey.dataset.noteId = noteId;
        blackKey.setAttribute('role', 'button');
        blackKey.setAttribute('aria-label', `${noteSystem === 'indian' ? note.indian : note.western} note`);
        blackKey.style.cssText = `left: ${centerX - 14}px; width: 28px; height: 88px;`;

        const labelEl = document.createElement('span');
        labelEl.className = 'key-label';
        labelEl.textContent = noteSystem === 'indian' ? note.western : note.western;
        labelEl.style.cssText = 'pointer-events: none; font-size: 7px; color: rgba(255,255,255,0.35); font-family: monospace;';
        blackKey.appendChild(labelEl);

        wrapper.appendChild(blackKey);
        bindKeyEvents(blackKey, noteId);
      });
    });

    // Bind events to white keys
    whiteKeyEls.forEach(({ el, note }) => {
      bindKeyEvents(el, note.id);
    });
  }

  function bindKeyEvents(el, noteId) {
    // Mouse
    el.addEventListener('mousedown', (e) => {
      e.preventDefault();
      startNote(noteId, el);
    });
    el.addEventListener('mouseup', () => stopNoteUI(noteId, el));
    el.addEventListener('mouseleave', () => stopNoteUI(noteId, el));

    // Touch
    el.addEventListener('touchstart', (e) => {
      e.preventDefault();
      startNote(noteId, el);
    }, { passive: false });
    el.addEventListener('touchend', (e) => {
      e.preventDefault();
      stopNoteUI(noteId, el);
    });
  }

  function startNote(noteId, el) {
    el.classList.add('active');
    playNote(noteId);
    const note = NOTES.find(n => n.id === noteId);
    if (note) {
      const display = document.getElementById('note-display');
      if (display) {
        display.textContent = noteSystem === 'indian' ? note.indian : note.western;
      }
    }
  }

  function stopNoteUI(noteId, el) {
    el.classList.remove('active');
    stopNote(noteId);
  }

  // ─── Keyboard Shortcuts ───────────────────────────────────────────────
  const shortcutMap = {};
  NOTES.forEach(n => { if (n.shortcut) shortcutMap[n.shortcut] = n.id; });
  const pressedKeys = new Set();

  document.addEventListener('keydown', (e) => {
    if (e.repeat) return;
    const key = e.key.toLowerCase();

    if (key === 'arrowleft') { changeOctave(-1); return; }
    if (key === 'arrowright') { changeOctave(1); return; }

    const noteId = shortcutMap[key];
    if (noteId && !pressedKeys.has(key)) {
      pressedKeys.add(key);
      const el = document.querySelector(`[data-note-id="${noteId}"]`);
      if (el) startNote(noteId, el);
    }
  });

  document.addEventListener('keyup', (e) => {
    const key = e.key.toLowerCase();
    const noteId = shortcutMap[key];
    if (noteId) {
      pressedKeys.delete(key);
      const el = document.querySelector(`[data-note-id="${noteId}"]`);
      if (el) stopNoteUI(noteId, el);
    }
  });

  // ─── Controls ─────────────────────────────────────────────────────────
  function changeOctave(delta) {
    currentOctave = Math.max(2, Math.min(6, currentOctave + delta));
    const display = document.getElementById('octave-display');
    if (display) display.textContent = `Oct: ${currentOctave}`;
  }

  document.getElementById('oct-down')?.addEventListener('click', () => changeOctave(-1));
  document.getElementById('oct-up')?.addEventListener('click', () => changeOctave(1));

  document.getElementById('volume-slider')?.addEventListener('input', (e) => {
    if (masterGain) {
      masterGain.gain.value = parseFloat(e.target.value) / 100;
    }
  });

  document.getElementById('sound-toggle')?.addEventListener('click', () => {
    soundEnabled = !soundEnabled;
    const btn = document.getElementById('sound-toggle');
    if (btn) {
      if (soundEnabled) {
        btn.innerHTML = '<span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span> Sound ON';
        btn.className = btn.className.replace('red', 'green').replace(/bg-\S+-500\/20 border-\S+-500\/30 text-\S+-400/, 'bg-green-500/20 border-green-500/30 text-green-400');
      } else {
        btn.innerHTML = '<span class="w-2 h-2 rounded-full bg-red-400"></span> Sound OFF';
      }
    }
    // Stop all active notes
    [...activeNodes.keys()].forEach(id => {
      const el = document.querySelector(`[data-note-id="${id}"]`);
      if (el) stopNoteUI(id, el);
    });
  });

  // Note system toggle
  document.getElementById('btn-indian')?.addEventListener('click', () => {
    noteSystem = 'indian';
    document.getElementById('btn-indian')?.classList.add('bg-saffron-500', 'text-white');
    document.getElementById('btn-indian')?.classList.remove('text-ivory/60');
    document.getElementById('btn-western')?.classList.remove('bg-saffron-500', 'text-white');
    document.getElementById('btn-western')?.classList.add('text-ivory/60');
    renderKeyboard();
  });

  document.getElementById('btn-western')?.addEventListener('click', () => {
    noteSystem = 'western';
    document.getElementById('btn-western')?.classList.add('bg-saffron-500', 'text-white');
    document.getElementById('btn-western')?.classList.remove('text-ivory/60');
    document.getElementById('btn-indian')?.classList.remove('bg-saffron-500', 'text-white');
    document.getElementById('btn-indian')?.classList.add('text-ivory/60');
    renderKeyboard();
  });

  // Bellows click to init audio
  document.getElementById('bellows')?.addEventListener('click', () => {
    initAudio();
    if (audioCtx?.state === 'suspended') audioCtx.resume();
  });

  // ─── Init ─────────────────────────────────────────────────────────────
  renderKeyboard();
})();
</script>

<style>
.harmonium-widget {
  background: linear-gradient(135deg, #2d1207 0%, #3d1a0a 50%, #2a1005 100%);
  border-radius: 16px;
  padding: 20px;
  box-shadow: 
    0 30px 70px rgba(0,0,0,0.4),
    inset 0 1px 0 rgba(255,200,80,0.15),
    0 0 0 1px rgba(120,60,20,0.5);
}
</style>
