---
const links = [
  { href:'/',          label:'Home'     },
  { href:'/lessons',   label:'Lessons'  },
  { href:'/practice',  label:'Practice' },
  { href:'/notes',     label:'Notes'    },
  { href:'/blog',      label:'Blog'     },
  { href:'/about',     label:'About'    },
];
---

<header class="sticky top-0 z-50" style="background:rgba(28,16,8,.97);backdrop-filter:blur(12px);border-bottom:1px solid rgba(212,146,10,.15)">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-14 sm:h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0" aria-label="Harmonium Halt Home">
        <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg flex items-center justify-center flex-shrink-0"
             style="background:linear-gradient(135deg,#c8360a,#7a0000)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <rect x="2"  y="14" width="2.2" height="7" rx="1.1" fill="white"/>
            <rect x="5.2" y="11" width="2.2" height="10" rx="1.1" fill="white"/>
            <rect x="8.4" y="14" width="2.2" height="7" rx="1.1" fill="white"/>
            <rect x="11.6" y="9"  width="2.2" height="12" rx="1.1" fill="white"/>
            <rect x="14.8" y="14" width="2.2" height="7" rx="1.1" fill="white"/>
            <rect x="18"  y="11" width="2.2" height="10" rx="1.1" fill="white"/>
            <rect x="4"   y="6"  width="1.6" height="8"  rx=".8" fill="#f0aa0e"/>
            <rect x="7.2" y="6"  width="1.6" height="8"  rx=".8" fill="#f0aa0e"/>
            <rect x="13.6" y="5" width="1.6" height="9"  rx=".8" fill="#f0aa0e"/>
            <rect x="16.8" y="6" width="1.6" height="8"  rx=".8" fill="#f0aa0e"/>
          </svg>
        </div>
        <div class="leading-none">
          <span class="block font-display font-bold text-base sm:text-lg leading-none" style="color:#f0aa0e">Harmonium</span>
          <span class="block text-xs tracking-widest uppercase" style="color:rgba(250,246,239,.5);font-family:'Plus Jakarta Sans',sans-serif">Halt</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {links.map(l => (
          <a href={l.href}
             class="px-3 py-2 rounded-lg text-sm font-medium transition-colors"
             style="color:rgba(250,246,239,.7);font-family:'Plus Jakarta Sans',sans-serif"
             onmouseover="this.style.color='#f0aa0e';this.style.background='rgba(255,255,255,.06)'"
             onmouseout="this.style.color='rgba(250,246,239,.7)';this.style.background='transparent'">
            {l.label}
          </a>
        ))}
      </nav>

      <!-- CTA + hamburger -->
      <div class="flex items-center gap-2 sm:gap-3">
        <a href="/practice" class="hidden sm:inline-flex items-center gap-1.5 text-white text-xs sm:text-sm font-bold px-3 sm:px-4 py-2 rounded-xl transition-all"
           style="background:linear-gradient(135deg,#c8360a,#e8430c);font-family:'Plus Jakarta Sans',sans-serif;box-shadow:0 4px 12px rgba(200,54,10,.35)">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
          <span class="hidden xs:inline">Play Now</span>
          <span class="xs:hidden">Play</span>
        </a>
        <button id="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu"
                class="lg:hidden flex items-center justify-center w-9 h-9 rounded-lg"
                style="color:rgba(250,246,239,.8);background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1)">
          <svg id="icon-open"  width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="hidden">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 pt-2" role="navigation" aria-label="Mobile navigation">
      <div class="flex flex-col gap-0.5">
        {links.map(l => (
          <a href={l.href}
             class="flex items-center px-4 py-3 rounded-xl text-sm font-medium transition-colors nav-mobile-link"
             style="color:rgba(250,246,239,.75);font-family:'Plus Jakarta Sans',sans-serif">
            {l.label}
          </a>
        ))}
        <a href="/practice"
           class="mt-2 flex items-center justify-center gap-2 py-3 rounded-xl font-bold text-sm text-white"
           style="background:linear-gradient(135deg,#c8360a,#e8430c);font-family:'Plus Jakarta Sans',sans-serif">
          🎵 Play Web Harmonium
        </a>
      </div>
    </div>
  </div>
</header>

<script>
(function(){
  const btn   = document.getElementById('nav-toggle');
  const menu  = document.getElementById('mobile-menu');
  const open  = document.getElementById('icon-open');
  const close = document.getElementById('icon-close');
  if (!btn || !menu) return;

  btn.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu.classList.toggle('hidden');
    open.classList.toggle('hidden');
    close.classList.toggle('hidden');
  });

  // close on link click
  menu.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      open.classList.remove('hidden');
      close.classList.add('hidden');
      btn.setAttribute('aria-expanded','false');
    })
  );

  // hover style for mobile links
  menu.querySelectorAll('.nav-mobile-link').forEach(a => {
    a.addEventListener('mouseenter', ()=>{ a.style.color='#f0aa0e'; a.style.background='rgba(255,255,255,.06)'; });
    a.addEventListener('mouseleave', ()=>{ a.style.color='rgba(250,246,239,.75)'; a.style.background='transparent'; });
  });
})();
</script>
