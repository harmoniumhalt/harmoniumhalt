---
const year = new Date().getFullYear();
---

<footer style="background:#1c1008;color:rgba(250,246,239,.65)" class="safe-bottom">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 sm:pt-14 pb-6 sm:pb-8">

    <!-- Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-10 mb-10">

      <!-- Brand -->
      <div class="col-span-2 sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0"
               style="background:linear-gradient(135deg,#c8360a,#7a0000)">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none">
              <rect x="2"  y="14" width="2.2" height="7" rx="1.1" fill="white"/>
              <rect x="5.2" y="11" width="2.2" height="10" rx="1.1" fill="white"/>
              <rect x="8.4" y="14" width="2.2" height="7" rx="1.1" fill="white"/>
              <rect x="11.6" y="9" width="2.2" height="12" rx="1.1" fill="white"/>
              <rect x="14.8" y="14" width="2.2" height="7" rx="1.1" fill="white"/>
              <rect x="18"  y="11" width="2.2" height="10" rx="1.1" fill="white"/>
            </svg>
          </div>
          <span class="font-display font-bold text-lg" style="color:#f0aa0e">Harmonium Halt</span>
        </a>
        <p class="text-sm leading-relaxed mb-3" style="font-family:'Plus Jakarta Sans',sans-serif">
          India's premier free online harmonium learning platform. Play, learn, and practice anytime.
        </p>
        <p class="text-xs italic font-display" style="color:#d4920a">
          "Play Online Web Harmonium, Learn Easily, Practice Daily"
        </p>
      </div>

      <!-- Learn -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-wider mb-4" style="color:rgba(250,246,239,.9);font-family:'Plus Jakarta Sans',sans-serif">Learn</h3>
        <ul class="space-y-2.5 text-sm" style="font-family:'Plus Jakarta Sans',sans-serif">
          {[
            ['/lessons','All Lessons'],
            ['/lessons/introduction-to-harmonium','Beginner Start'],
            ['/lessons/alankars','Alankars'],
            ['/lessons/ragas-introduction','Ragas'],
            ['/notes','Notes & Downloads'],
          ].map(([h,l]) => (
            <li><a href={h} class="hover:text-yellow-400 transition-colors" style="color:rgba(250,246,239,.6)">{l}</a></li>
          ))}
        </ul>
      </div>

      <!-- Practice -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-wider mb-4" style="color:rgba(250,246,239,.9);font-family:'Plus Jakarta Sans',sans-serif">Practice</h3>
        <ul class="space-y-2.5 text-sm" style="font-family:'Plus Jakarta Sans',sans-serif">
          {[
            ['/practice','Web Harmonium'],
            ['/blog','Blog'],
            ['/about','About'],
            ['/contact','Contact'],
          ].map(([h,l]) => (
            <li><a href={h} class="hover:text-yellow-400 transition-colors" style="color:rgba(250,246,239,.6)">{l}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-wider mb-4" style="color:rgba(250,246,239,.9);font-family:'Plus Jakarta Sans',sans-serif">Legal</h3>
        <ul class="space-y-2.5 text-sm" style="font-family:'Plus Jakarta Sans',sans-serif">
          {[
            ['/privacy-policy','Privacy Policy'],
            ['/terms','Terms of Use'],
            ['/disclaimer','Disclaimer'],
            ['/sitemap.xml','Sitemap'],
          ].map(([h,l]) => (
            <li><a href={h} class="hover:text-yellow-400 transition-colors" style="color:rgba(250,246,239,.6)">{l}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs"
         style="border-color:rgba(255,255,255,.08);font-family:'Plus Jakarta Sans',sans-serif">
      <p>© {year} Harmonium Halt. All rights reserved.</p>
      <p style="color:rgba(250,246,239,.35)">Made with ♥ for music learners across India</p>
    </div>
  </div>
</footer>
