---
const currentYear = new Date().getFullYear();
---

<footer class="bg-ebony text-ivory/70">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 bg-gradient-to-br from-saffron-400 to-burgundy-700 rounded-lg flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="14" width="2" height="6" rx="1" fill="white"/><rect x="5" y="12" width="2" height="8" rx="1" fill="white"/><rect x="8" y="14" width="2" height="6" rx="1" fill="white"/><rect x="11" y="11" width="2" height="9" rx="1" fill="white"/><rect x="14" y="14" width="2" height="6" rx="1" fill="white"/><rect x="17" y="12" width="2" height="8" rx="1" fill="white"/><rect x="20" y="14" width="2" height="6" rx="1" fill="white"/></svg>
          </div>
          <span class="font-display font-bold text-gold-400 text-lg">Harmonium Halt</span>
        </a>
        <p class="text-sm leading-relaxed mb-4">
          India's premier online harmonium learning platform. Play, learn, and practice harmonium from the comfort of your home.
        </p>
        <p class="text-xs font-medium text-saffron-400 italic font-display">
          "Play Online Web Harmonium, Learn Easily, Practice Daily"
        </p>
      </div>

      <!-- Learn -->
      <div>
        <h3 class="font-display font-semibold text-ivory mb-4 text-sm uppercase tracking-wider">Learn</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/lessons" class="hover:text-gold-400 transition-colors">All Lessons</a></li>
          <li><a href="/lessons/beginner" class="hover:text-gold-400 transition-colors">Beginner Course</a></li>
          <li><a href="/lessons/intermediate" class="hover:text-gold-400 transition-colors">Intermediate Course</a></li>
          <li><a href="/lessons/advanced" class="hover:text-gold-400 transition-colors">Advanced Course</a></li>
          <li><a href="/notes" class="hover:text-gold-400 transition-colors">Notes & Downloads</a></li>
        </ul>
      </div>

      <!-- Practice -->
      <div>
        <h3 class="font-display font-semibold text-ivory mb-4 text-sm uppercase tracking-wider">Practice</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/practice" class="hover:text-gold-400 transition-colors">Web Harmonium</a></li>
          <li><a href="/practice#scales" class="hover:text-gold-400 transition-colors">Scales & Alankars</a></li>
          <li><a href="/practice#ragas" class="hover:text-gold-400 transition-colors">Raga Practice</a></li>
          <li><a href="/blog" class="hover:text-gold-400 transition-colors">Blog & Tips</a></li>
          <li><a href="/about" class="hover:text-gold-400 transition-colors">About Us</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-display font-semibold text-ivory mb-4 text-sm uppercase tracking-wider">Site Info</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="hover:text-gold-400 transition-colors">About</a></li>
          <li><a href="/contact" class="hover:text-gold-400 transition-colors">Contact</a></li>
          <li><a href="/privacy-policy" class="hover:text-gold-400 transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-gold-400 transition-colors">Terms of Use</a></li>
          <li><a href="/disclaimer" class="hover:text-gold-400 transition-colors">Disclaimer</a></li>
          <li><a href="/sitemap.xml" class="hover:text-gold-400 transition-colors">Sitemap</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs">
      <p>© {currentYear} Harmonium Halt. All rights reserved.</p>
      <p class="text-ivory/40">Made with ♥ for music learners across India</p>
    </div>
  </div>
</footer>
