---
import Layout from '../layouts/Layout.astro';
import Harmonium from '../components/Harmonium.astro';
import LessonCard from '../components/LessonCard.astro';
import BlogCard from '../components/BlogCard.astro';

const featuredLessons = [
  { title: 'Introduction to Harmonium', description: 'Learn what a harmonium is, its history, and how it works. Perfect starting point for absolute beginners.', href: '/lessons/introduction-to-harmonium', level: 'beginner', duration: '10 min', icon: '🎹' },
  { title: 'Sa Re Ga Ma — Indian Sargam', description: 'Master the seven swaras of Indian classical music: Sa, Re, Ga, Ma, Pa, Dha, Ni on harmonium.', href: '/lessons/sa-re-ga-ma', level: 'beginner', duration: '20 min', icon: '🎵' },
  { title: 'Finger Placement & Technique', description: 'Correct posture and finger placement for smooth harmonium playing. Build the right foundation from day one.', href: '/lessons/finger-placement', level: 'beginner', duration: '15 min', icon: '👐' },
  { title: 'Alankars for Practice', description: 'Daily practice patterns called Alankars to build speed, accuracy, and muscle memory on the harmonium.', href: '/lessons/alankars', level: 'intermediate', duration: '25 min', icon: '🔄' },
  { title: 'Introduction to Ragas', description: 'Understand what a Raga is and learn your first raga — Yaman — one of the most popular ragas in Indian music.', href: '/lessons/ragas-introduction', level: 'intermediate', duration: '30 min', icon: '🌙' },
  { title: 'Bhajans on Harmonium', description: 'Play popular Hindi bhajans step-by-step. Includes notations for Raghupati Raghav and Vaishnav Jan To.', href: '/lessons/bhajans', level: 'beginner', duration: '20 min', icon: '🙏' },
];

const featuredBlogs = [
  { title: 'How to Learn Harmonium at Home: Complete Beginner Guide 2024', description: 'Everything you need to start your harmonium journey from home — no guru required.', href: '/blog/learn-harmonium-at-home', date: 'Dec 10, 2024', category: 'Beginner', readTime: '8 min read' },
  { title: 'Best Harmonium for Beginners in India 2024', description: 'Top harmoniums reviewed and compared for Indian beginners on a budget.', href: '/blog/best-harmonium-for-beginners', date: 'Dec 5, 2024', category: 'Buying Guide', readTime: '10 min read' },
  { title: 'Sa Re Ga Ma Pa: Complete Guide to Indian Sargam', description: 'Deep dive into the seven swaras, komal-tivra notes, and how to read sargam notation.', href: '/blog/sa-re-ga-ma-pa-guide', date: 'Dec 1, 2024', category: 'Theory', readTime: '12 min read' },
];
---

<Layout
  title="Harmonium Halt — Play Online Web Harmonium, Learn Easily, Practice Daily"
  description="Play a real harmonium online in your browser. Learn Sa Re Ga Ma, ragas, bhajans and more with structured lessons from beginner to advanced. Free harmonium lessons in Hindi & English."
>
  <!-- ═══ HERO SECTION ═══ -->
  <section class="relative overflow-hidden bg-gradient-to-br from-ebony via-wood-dark to-burgundy-950 text-white py-12 md:py-16">
    <!-- Background ornament -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute top-0 right-0 w-96 h-96 bg-saffron-500 rounded-full blur-3xl transform translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-burgundy-600 rounded-full blur-3xl transform -translate-x-1/2 translate-y-1/2"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 items-start">
        <!-- Left: Text + CTA -->
        <div class="pt-4">
          <div class="inline-flex items-center gap-2 bg-saffron-500/15 border border-saffron-500/30 text-saffron-300 text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
            <span class="w-1.5 h-1.5 bg-saffron-400 rounded-full animate-pulse"></span>
            🎵 Free Online Harmonium — Play Now in Browser
          </div>
          <h1 class="font-display font-black text-4xl md:text-5xl lg:text-4xl xl:text-5xl leading-tight mb-4">
            Learn <span class="text-transparent bg-clip-text bg-gradient-to-r from-saffron-400 to-gold-400">Harmonium</span><br/>
            Online — Free
          </h1>
          <p class="text-lg text-ivory/70 mb-2 font-display italic">
            "Play Online Web Harmonium, Learn Easily, Practice Daily"
          </p>
          <p class="text-ivory/60 text-sm mb-8 leading-relaxed max-w-md">
            India's most complete online harmonium learning platform. Play our interactive web harmonium, follow structured lessons, and master Indian classical music — all for free.
          </p>

          <div class="flex flex-wrap gap-3 mb-8">
            <a href="/lessons" class="bg-saffron-500 hover:bg-saffron-400 text-white font-bold px-6 py-3 rounded-xl transition-all shadow-lg shadow-saffron-500/25 flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Start Learning Free
            </a>
            <a href="#harmonium" class="bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-xl transition-all border border-white/20 flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Play Harmonium
            </a>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-3 gap-4">
            <div class="text-center">
              <div class="font-display font-black text-2xl text-gold-400">50+</div>
              <div class="text-xs text-ivory/50 mt-0.5">Lessons</div>
            </div>
            <div class="text-center">
              <div class="font-display font-black text-2xl text-gold-400">20+</div>
              <div class="text-xs text-ivory/50 mt-0.5">Ragas</div>
            </div>
            <div class="text-center">
              <div class="font-display font-black text-2xl text-gold-400">100%</div>
              <div class="text-xs text-ivory/50 mt-0.5">Free</div>
            </div>
          </div>
        </div>

        <!-- Right: Harmonium Widget -->
        <div id="harmonium" class="w-full">
          <div class="mb-3 flex items-center gap-2">
            <span class="text-xs text-ivory/50 bg-white/5 px-3 py-1 rounded-full border border-white/10">
              🎹 Click keys or use keyboard (A S D F G H J K L) to play
            </span>
          </div>
          <Harmonium />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="py-14 bg-ivory">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-3xl text-ebony mb-3">How Harmonium Halt Works</h2>
        <p class="text-ebony/60 max-w-xl mx-auto">A complete music learning ecosystem, from absolute beginner to advanced performer.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { step: '01', icon: '🎹', title: 'Play Instantly', desc: 'Open our web harmonium and start making music immediately — no download or setup needed.' },
          { step: '02', icon: '📖', title: 'Follow Lessons', desc: 'Structured curriculum from Sa Re Ga Ma to advanced ragas and compositions.' },
          { step: '03', icon: '🔄', title: 'Practice Daily', desc: 'Use our built-in practice tools, alankars, and daily riyaaz exercises to build skill.' },
          { step: '04', icon: '🎵', title: 'Play Songs', desc: 'Learn bhajans, film songs, classical ragas, and more with detailed notations.' },
        ].map(item => (
          <div class="text-center p-6 rounded-2xl bg-white border border-ebony/6 shadow-sm hover:shadow-md transition-shadow">
            <div class="text-xs font-mono font-bold text-saffron-400 mb-2">{item.step}</div>
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-display font-bold text-ebony mb-2">{item.title}</h3>
            <p class="text-sm text-ebony/60 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED LESSONS ═══ -->
  <section class="py-14 bg-gradient-to-b from-ivory to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="font-display font-bold text-3xl text-ebony mb-1">Start Learning Today</h2>
          <p class="text-ebony/60">Structured lessons for every skill level</p>
        </div>
        <a href="/lessons" class="text-sm font-semibold text-saffron-600 hover:text-saffron-500 flex items-center gap-1">
          View All
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {featuredLessons.map(lesson => (
          <LessonCard {...lesson} level={lesson.level as any} />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ YOUTUBE EMBED ═══ -->
  <section class="py-14 bg-ebony text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display font-bold text-3xl mb-3">Watch: Harmonium for Beginners</h2>
      <p class="text-ivory/60 mb-8">Get started with this comprehensive video tutorial on harmonium basics.</p>
      <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-white/10" style="padding-bottom: 56.25%;">
        <iframe
          class="absolute inset-0 w-full h-full"
          src="https://www.youtube.com/embed/dQw4w9WgXcQ?rel=0"
          title="Harmonium Basics Tutorial"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <p class="text-xs text-ivory/30 mt-3">Tutorial by Harmonium Halt educators</p>
    </div>
  </section>

  <!-- ═══ BENEFITS ═══ -->
  <section class="py-14 bg-ivory">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display font-bold text-3xl text-ebony mb-4">Why Learn Harmonium at Harmonium Halt?</h2>
          <div class="space-y-4">
            {[
              { icon: '🆓', title: 'Completely Free', desc: 'All lessons, tools, and resources are 100% free — no subscription, no hidden fees.' },
              { icon: '🎹', title: 'Real Web Harmonium', desc: 'Play a realistic harmonium in your browser using Web Audio API — no app download needed.' },
              { icon: '🇮🇳', title: 'Indian & Western Notation', desc: 'Learn in Sa Re Ga Ma (Indian sargam) or C D E (western notation) — your choice.' },
              { icon: '📱', title: 'Mobile Friendly', desc: 'Practice on phone, tablet, or desktop. The harmonium keyboard adapts to any screen size.' },
              { icon: '📚', title: 'Structured Curriculum', desc: 'Follow a proven learning path: basics → sargam → alankars → ragas → compositions.' },
              { icon: '🎓', title: 'Expert Content', desc: 'Lessons crafted by experienced Indian classical musicians and music educators.' },
            ].map(b => (
              <div class="flex gap-4">
                <div class="text-2xl flex-shrink-0">{b.icon}</div>
                <div>
                  <h3 class="font-semibold text-ebony mb-0.5">{b.title}</h3>
                  <p class="text-sm text-ebony/60">{b.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-gradient-to-br from-burgundy-900 to-ebony rounded-2xl p-8 text-white">
          <h3 class="font-display font-bold text-xl text-gold-400 mb-6">What You'll Learn</h3>
          <div class="space-y-3">
            {[
              'Harmonium anatomy and parts',
              'Sa Re Ga Ma (7 swaras + komal/tivra)',
              'Proper finger placement and posture',
              'Alankars — 10 essential patterns',
              'Popular bhajans and devotional songs',
              'Major ragas: Yaman, Bhairav, Bhairavi',
              'Chord progressions',
              'Reading and writing sargam notation',
              'Classical improvisation techniques',
            ].map(item => (
              <div class="flex items-center gap-3 text-sm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-saffron-400 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-ivory/80">{item}</span>
              </div>
            ))}
          </div>
          <a href="/lessons" class="mt-6 block text-center bg-saffron-500 hover:bg-saffron-400 text-white font-bold py-3 rounded-xl transition-all">
            View Full Curriculum →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ═══ -->
  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-bold text-3xl text-ebony text-center mb-10">What Our Learners Say</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { name: 'Priya Sharma', city: 'Delhi', text: 'I always wanted to learn harmonium but never had access to a teacher. Harmonium Halt changed everything. The web harmonium is incredible!', stars: 5 },
          { name: 'Ramesh Gupta', city: 'Mumbai', text: 'The Sa Re Ga Ma lessons are so well-explained. I can now play simple bhajans after just 2 weeks of practice. Thank you!', stars: 5 },
          { name: 'Ananya Singh', city: 'Bangalore', text: 'Best free music learning site I have found. The alankars section helped me build speed and accuracy I never had before.', stars: 5 },
          { name: 'Mohit Verma', city: 'Jaipur', text: 'Playing harmonium on the browser is so satisfying. The keyboard shortcuts make practice sessions so efficient.', stars: 5 },
          { name: 'Kavita Pandey', city: 'Varanasi', text: 'As a classical music enthusiast, I appreciate the depth of content. The raga lessons are particularly well-written.', stars: 5 },
          { name: 'Arjun Nair', city: 'Chennai', text: 'I was skeptical about learning an instrument online but Harmonium Halt proved me wrong. Excellent platform!', stars: 5 },
        ].map(t => (
          <div class="bg-ivory rounded-xl p-5 border border-ebony/6">
            <div class="flex mb-2">
              {'★'.repeat(t.stars).split('').map(() => (
                <span class="text-gold-500 text-sm">★</span>
              ))}
            </div>
            <p class="text-sm text-ebony/70 italic mb-4 leading-relaxed">"{t.text}"</p>
            <div class="font-semibold text-sm text-ebony">{t.name}</div>
            <div class="text-xs text-ebony/40">{t.city}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ BLOG PREVIEW ═══ -->
  <section class="py-14 bg-ivory">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="font-display font-bold text-3xl text-ebony mb-1">Latest from the Blog</h2>
          <p class="text-ebony/60">Tips, guides, and insights for harmonium learners</p>
        </div>
        <a href="/blog" class="text-sm font-semibold text-saffron-600 hover:text-saffron-500 flex items-center gap-1">
          All Articles
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {featuredBlogs.map(blog => (
          <BlogCard {...blog} />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FINAL CTA ═══ -->
  <section class="py-16 bg-gradient-to-br from-burgundy-900 via-ebony to-wood-dark text-white text-center">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-4xl mb-4">🎹</div>
      <h2 class="font-display font-black text-4xl mb-4">Ready to Play Harmonium?</h2>
      <p class="text-ivory/70 mb-8 text-lg">Start for free. No downloads, no registration. Just music.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#harmonium" class="bg-saffron-500 hover:bg-saffron-400 text-white font-bold px-8 py-4 rounded-xl text-lg transition-all shadow-xl">
          🎵 Play Web Harmonium
        </a>
        <a href="/lessons" class="bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-4 rounded-xl text-lg transition-all border border-white/20">
          📖 Start Learning
        </a>
      </div>
    </div>
  </section>
</Layout>
