---
import Layout from '../layouts/Layout.astro';
import Harmonium from '../components/Harmonium.astro';
import LessonCard from '../components/LessonCard.astro';
import BlogCard from '../components/BlogCard.astro';

const lessons = [
  {title:'Introduction to Harmonium',description:'Learn parts, history, and your first sounds.',href:'/lessons/introduction-to-harmonium',level:'beginner',duration:'10 min',icon:'🎹'},
  {title:'Sa Re Ga Ma — Seven Swaras',description:'Master India\'s musical alphabet on the keyboard.',href:'/lessons/sa-re-ga-ma',level:'beginner',duration:'20 min',icon:'🎵'},
  {title:'Finger Placement & Posture',description:'Build the right physical foundation from day one.',href:'/lessons/finger-placement',level:'beginner',duration:'15 min',icon:'👐'},
  {title:'Alankars — Daily Patterns',description:'10 essential practice patterns for speed and accuracy.',href:'/lessons/alankars',level:'intermediate',duration:'30 min',icon:'🔄'},
  {title:'Introduction to Ragas',description:'Understand aroha, avaroha, vadi, and raga time theory.',href:'/lessons/ragas-introduction',level:'intermediate',duration:'25 min',icon:'🌙'},
  {title:'Bhajans on Harmonium',description:'Play popular devotional songs step by step.',href:'/lessons/bhajans',level:'beginner',duration:'20 min',icon:'🙏'},
];

const blogs = [
  {title:'How to Learn Harmonium at Home: Complete Guide 2024',description:'Step-by-step guide to self-teaching harmonium from scratch.',href:'/blog/learn-harmonium-at-home',date:'Dec 10, 2024',category:'Beginner',readTime:'8 min'},
  {title:'Best Harmonium for Beginners in India 2024',description:'Top 10 harmoniums reviewed for Indian beginners at every budget.',href:'/blog/best-harmonium-for-beginners',date:'Dec 5, 2024',category:'Buying Guide',readTime:'10 min'},
  {title:'Sa Re Ga Ma Pa — Complete Sargam Guide',description:'Deep dive into India\'s musical notation system.',href:'/blog/sa-re-ga-ma-pa-guide',date:'Dec 1, 2024',category:'Theory',readTime:'12 min'},
];

const stats = [
  {n:'50+',  l:'Free Lessons'},
  {n:'25+',  l:'Blog Articles'},
  {n:'2+',   l:'Octaves'},
  {n:'100%', l:'Free'},
];

const benefits = [
  {icon:'🆓', title:'Completely Free', desc:'Every lesson, tool, and resource — forever free, no sign-up needed.'},
  {icon:'🎹', title:'Real Web Harmonium', desc:'Browser-based instrument with Web Audio API — genuine reed-like sound.'},
  {icon:'🇮🇳', title:'Indian & Western', desc:'Toggle between Sa Re Ga Ma or C D E notation instantly.'},
  {icon:'📱', title:'Mobile Friendly', desc:'Fully responsive on any screen — phone, tablet, or desktop.'},
  {icon:'📚', title:'Structured Path', desc:'Beginner → Sargam → Alankars → Ragas → Compositions.'},
  {icon:'🎓', title:'Expert Content', desc:'Lessons from experienced Hindustani classical musicians.'},
];

const testimonials = [
  {name:'Priya Sharma',city:'Delhi',text:'I always wanted to learn harmonium. Harmonium Halt changed everything — the web harmonium is incredible!'},
  {name:'Ramesh Gupta',city:'Mumbai',text:'The Sa Re Ga Ma lessons are so clear. I can play simple bhajans after just 2 weeks. Thank you!'},
  {name:'Ananya Singh',city:'Bangalore',text:'Best free music learning platform I have found. The alankars section built my speed dramatically.'},
  {name:'Mohit Verma',city:'Jaipur',text:'Playing harmonium in the browser is so satisfying. Keyboard shortcuts make practice super efficient.'},
  {name:'Kavita Pandey',city:'Varanasi',text:'As a classical music enthusiast I appreciate the depth. The raga lessons are particularly well-written.'},
  {name:'Arjun Nair',city:'Chennai',text:'I was skeptical about learning online but Harmonium Halt proved me wrong. Excellent platform!'},
];
---

<Layout title="Harmonium Halt — Play Online Web Harmonium, Learn Easily, Practice Daily"
  description="Play a real harmonium online in your browser. Free structured lessons from beginner to advanced — Sa Re Ga Ma, alankars, ragas, bhajans. India's best free harmonium learning platform.">

  <!-- ═══════════════ HERO ═══════════════ -->
  <section style="background:linear-gradient(150deg,#1c1008 0%,#3d1a08 50%,#1a0804 100%)" class="relative overflow-hidden">

    <!-- BG orbs -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-20 -right-20 w-64 sm:w-96 h-64 sm:h-96 rounded-full opacity-10" style="background:radial-gradient(circle,#c8360a,transparent)"></div>
      <div class="absolute -bottom-20 -left-20 w-48 sm:w-72 h-48 sm:h-72 rounded-full opacity-8" style="background:radial-gradient(circle,#d4920a,transparent)"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14 lg:py-16">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-start">

        <!-- Left text -->
        <div class="order-1">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 mb-5 px-3 py-1.5 rounded-full text-xs font-bold"
               style="background:rgba(200,54,10,.18);border:1px solid rgba(200,54,10,.35);color:#f0aa0e;font-family:'Plus Jakarta Sans',sans-serif">
            <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#f0aa0e"></span>
            🎵 Free — No Sign-up — Play Instantly
          </div>

          <h1 class="section-title text-3xl xs:text-4xl sm:text-5xl lg:text-4xl xl:text-5xl leading-tight mb-4" style="color:#faf6ef">
            Learn <span style="color:#f0aa0e">Harmonium</span><br class="hidden xs:block"/>
            Online — Free
          </h1>
          <p class="font-display italic mb-2 text-base sm:text-lg" style="color:rgba(240,170,14,.75)">"Play Online Web Harmonium, Learn Easily, Practice Daily"</p>
          <p class="text-sm sm:text-base mb-7 leading-relaxed max-w-lg" style="color:rgba(250,246,239,.6);font-family:'Plus Jakarta Sans',sans-serif">
            India's most complete online harmonium platform. Play our interactive web harmonium, follow structured lessons, and master Indian classical music — all for free.
          </p>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-3 mb-8">
            <a href="/lessons" class="btn-primary">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Start Learning Free
            </a>
            <a href="#harmonium" class="btn-secondary">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
              Play Harmonium
            </a>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-4 gap-3 sm:gap-4">
            {stats.map(s=>(
              <div class="text-center">
                <div class="font-display font-black text-xl sm:text-2xl" style="color:#f0aa0e">{s.n}</div>
                <div class="text-xs mt-0.5" style="color:rgba(250,246,239,.45);font-family:'Plus Jakarta Sans',sans-serif">{s.l}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Harmonium -->
        <div class="order-2 w-full" id="harmonium">
          <div class="mb-2 flex items-center gap-2 flex-wrap">
            <span class="text-xs px-3 py-1 rounded-full" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);color:rgba(250,246,239,.5);font-family:'JetBrains Mono',monospace">
              🎹 Click keys or use A-L keyboard shortcuts
            </span>
          </div>
          <Harmonium/>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ HOW IT WORKS ═══════════════ -->
  <section class="py-12 sm:py-16" style="background:#faf6ef">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 sm:mb-10">
        <h2 class="section-title text-2xl sm:text-3xl mb-2" style="color:#1c1008">How Harmonium Halt Works</h2>
        <p class="text-sm sm:text-base" style="color:rgba(28,16,8,.55);font-family:'Plus Jakarta Sans',sans-serif">From zero to playing — a complete ecosystem</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
        {[
          {step:'01',icon:'🎹',title:'Play Instantly',desc:'Open our web harmonium and start making music right now — no download or setup.'},
          {step:'02',icon:'📖',title:'Follow Lessons',desc:'Structured curriculum from Sa Re Ga Ma basics to advanced ragas and compositions.'},
          {step:'03',icon:'🔄',title:'Practice Daily',desc:'Alankars, scales, and daily riyaaz exercises to build real skill systematically.'},
          {step:'04',icon:'🎵',title:'Play Songs',desc:'Learn bhajans, film songs, classical ragas with detailed sargam notations.'},
        ].map(s=>(
          <div class="bg-white rounded-2xl p-4 sm:p-6 text-center border" style="border-color:rgba(28,16,8,.06)">
            <div class="text-xs font-bold mb-2" style="color:#c8360a;font-family:'JetBrains Mono',monospace">{s.step}</div>
            <div class="text-2xl sm:text-3xl mb-2 sm:mb-3">{s.icon}</div>
            <h3 class="font-bold text-sm sm:text-base mb-1.5" style="color:#1c1008;font-family:'Plus Jakarta Sans',sans-serif">{s.title}</h3>
            <p class="text-xs sm:text-sm leading-relaxed" style="color:rgba(28,16,8,.55);font-family:'Plus Jakarta Sans',sans-serif">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ FEATURED LESSONS ═══════════════ -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-7 sm:mb-8 gap-4">
        <div>
          <h2 class="section-title text-2xl sm:text-3xl mb-1" style="color:#1c1008">Start Learning Today</h2>
          <p class="text-sm" style="color:rgba(28,16,8,.5);font-family:'Plus Jakarta Sans',sans-serif">Structured lessons for every skill level</p>
        </div>
        <a href="/lessons" class="text-xs sm:text-sm font-bold flex items-center gap-1 flex-shrink-0" style="color:#c8360a;font-family:'Plus Jakarta Sans',sans-serif;text-decoration:none">
          View All <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 xs:grid-cols-2 lg:grid-cols-3 gap-4">
        {lessons.map(l=><LessonCard {...l} level={l.level as any}/>)}
      </div>
    </div>
  </section>

  <!-- ═══════════════ YOUTUBE ═══════════════ -->
  <section class="py-12 sm:py-16" style="background:#1c1008">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="section-title text-2xl sm:text-3xl mb-2" style="color:#faf6ef">Watch: Harmonium for Beginners</h2>
      <p class="text-sm mb-6 sm:mb-8" style="color:rgba(250,246,239,.5);font-family:'Plus Jakarta Sans',sans-serif">Get started with a comprehensive beginner video tutorial</p>
      <div class="relative rounded-2xl overflow-hidden border" style="padding-bottom:56.25%;border-color:rgba(255,255,255,.1)">
        <iframe class="absolute inset-0 w-full h-full"
          src="https://www.youtube.com/embed/dQw4w9WgXcQ?rel=0"
          title="Harmonium Basics Tutorial for Beginners"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen loading="lazy"></iframe>
      </div>
    </div>
  </section>

  <!-- ═══════════════ BENEFITS ═══════════════ -->
  <section class="py-12 sm:py-16" style="background:#faf6ef">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 sm:gap-14 items-start">
        <!-- Benefits list -->
        <div>
          <h2 class="section-title text-2xl sm:text-3xl mb-6 sm:mb-8" style="color:#1c1008">Why Harmonium Halt?</h2>
          <div class="space-y-4 sm:space-y-5">
            {benefits.map(b=>(
              <div class="flex gap-3 sm:gap-4">
                <span class="text-xl sm:text-2xl flex-shrink-0 mt-0.5">{b.icon}</span>
                <div>
                  <h3 class="font-bold text-sm sm:text-base mb-0.5" style="color:#1c1008;font-family:'Plus Jakarta Sans',sans-serif">{b.title}</h3>
                  <p class="text-xs sm:text-sm leading-relaxed" style="color:rgba(28,16,8,.6);font-family:'Plus Jakarta Sans',sans-serif">{b.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- What you'll learn -->
        <div class="rounded-2xl p-6 sm:p-8 text-white" style="background:linear-gradient(135deg,#3d1a08,#1c1008)">
          <h3 class="font-display font-bold text-lg sm:text-xl mb-5" style="color:#f0aa0e">What You'll Learn</h3>
          <div class="space-y-2.5">
            {[
              'Harmonium anatomy and all parts',
              'Sa Re Ga Ma — 7 swaras + komal/tivra',
              'Proper finger placement and posture',
              'Alankars — 10 essential daily patterns',
              'Popular bhajans and devotional songs',
              'Major ragas: Yaman, Bhairav, Bhairavi',
              'Reading and writing sargam notation',
              'Chord progressions for accompaniment',
              'Classical improvisation techniques',
            ].map(item=>(
              <div class="flex items-center gap-3 text-xs sm:text-sm">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#f0aa0e" stroke-width="2.5" class="flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span style="color:rgba(250,246,239,.8);font-family:'Plus Jakarta Sans',sans-serif">{item}</span>
              </div>
            ))}
          </div>
          <a href="/lessons" class="btn-primary mt-6 w-full justify-center">
            View Full Curriculum →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ TESTIMONIALS ═══════════════ -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-2xl sm:text-3xl text-center mb-8 sm:mb-10" style="color:#1c1008">What Learners Say</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {testimonials.map(t=>(
          <div class="rounded-2xl p-4 sm:p-5 border" style="background:#faf6ef;border-color:rgba(28,16,8,.07)">
            <div class="flex mb-2">
              {'★★★★★'.split('').map(()=><span style="color:#d4920a;font-size:14px">★</span>)}
            </div>
            <p class="text-xs sm:text-sm italic mb-4 leading-relaxed" style="color:rgba(28,16,8,.65);font-family:'Plus Jakarta Sans',sans-serif">"{t.text}"</p>
            <div class="font-bold text-sm" style="color:#1c1008;font-family:'Plus Jakarta Sans',sans-serif">{t.name}</div>
            <div class="text-xs" style="color:rgba(28,16,8,.4);font-family:'Plus Jakarta Sans',sans-serif">{t.city}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ BLOG PREVIEW ═══════════════ -->
  <section class="py-12 sm:py-16" style="background:#faf6ef">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-7 gap-4">
        <div>
          <h2 class="section-title text-2xl sm:text-3xl mb-1" style="color:#1c1008">Latest from the Blog</h2>
          <p class="text-sm" style="color:rgba(28,16,8,.5);font-family:'Plus Jakarta Sans',sans-serif">Tips, guides, and insights for learners</p>
        </div>
        <a href="/blog" class="text-xs sm:text-sm font-bold flex items-center gap-1 flex-shrink-0" style="color:#c8360a;font-family:'Plus Jakarta Sans',sans-serif;text-decoration:none">
          All Articles <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {blogs.map(b=><BlogCard {...b}/>)}
      </div>
    </div>
  </section>

  <!-- ═══════════════ FINAL CTA ═══════════════ -->
  <section class="py-14 sm:py-20 text-center text-white" style="background:linear-gradient(135deg,#3d1a08,#1c1008,#0e0804)">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-4xl sm:text-5xl mb-4">🎹</div>
      <h2 class="section-title text-3xl sm:text-4xl mb-4" style="color:#faf6ef">Ready to Play Harmonium?</h2>
      <p class="mb-8 text-sm sm:text-base" style="color:rgba(250,246,239,.6);font-family:'Plus Jakarta Sans',sans-serif">Start for free. No downloads, no registration. Just music.</p>
      <div class="flex flex-col xs:flex-row gap-3 justify-center">
        <a href="#harmonium" class="btn-primary justify-center">🎵 Play Web Harmonium</a>
        <a href="/lessons"   class="btn-secondary justify-center">📖 Start Learning</a>
      </div>
    </div>
  </section>

</Layout>
