---
import Layout from '../../layouts/Layout.astro';
import Harmonium from '../../components/Harmonium.astro';
---

<Layout title="Play Online Harmonium — Free Web Harmonium Practice Tool | Harmonium Halt"
  description="Practice harmonium online free. Full-keyboard web harmonium with Indian & Western notation, octave controls, volume, and keyboard shortcuts. No download needed.">

  <div style="background:linear-gradient(160deg,#1c1008,#3d1a08,#1a0804)" class="min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">

      <!-- Header -->
      <div class="text-center mb-6 sm:mb-8">
        <h1 class="section-title text-2xl sm:text-3xl lg:text-4xl mb-2" style="color:#f0aa0e">Online Harmonium Practice</h1>
        <p class="text-xs sm:text-sm" style="color:rgba(250,246,239,.5);font-family:'Plus Jakarta Sans',sans-serif">Full-featured web harmonium — play, learn, and practice right in your browser</p>
      </div>

      <!-- Main Harmonium -->
      <Harmonium/>

      <!-- Instructions grid -->
      <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        {[
          {title:'⌨️ Keyboard Shortcuts', color:'rgba(240,170,14,.8)', items:['A–L = White keys (C to G2)','W E T Y U = Black keys','← → = Change octave','Multiple keys = Chords']},
          {title:'📱 Mobile / Touch',     color:'rgba(200,54,10,.9)',  items:['Tap any key to play','Hold for sustained note','Multi-touch for chords','Scroll keyboard sideways']},
          {title:'🎵 Practice Tips',      color:'rgba(74,222,128,.8)', items:['Start with Sa (A key)','Play Sa Re Ga Ma slowly','Sing notes as you play','Use metronome at 60 BPM']},
        ].map(c=>(
          <div class="rounded-xl p-4 border" style="background:rgba(255,255,255,.04);border-color:rgba(255,255,255,.08)">
            <h3 class="font-bold text-sm mb-3" style={`color:${c.color};font-family:'Plus Jakarta Sans',sans-serif`}>{c.title}</h3>
            <ul class="space-y-1.5">
              {c.items.map(i=>(
                <li class="text-xs" style="color:rgba(250,246,239,.55);font-family:'Plus Jakarta Sans',sans-serif">{i}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Sargam Reference Table -->
      <div class="mt-6 rounded-xl overflow-hidden border" style="background:rgba(255,255,255,.04);border-color:rgba(255,255,255,.08)">
        <div class="px-4 sm:px-5 py-3 border-b" style="border-color:rgba(255,255,255,.08)">
          <h2 class="font-bold text-sm sm:text-base" style="color:#f0aa0e;font-family:'Plus Jakarta Sans',sans-serif">🎼 Sargam Reference — All 12 Notes</h2>
        </div>
        <div class="table-wrap">
          <table class="w-full text-xs sm:text-sm" style="min-width:500px">
            <thead>
              <tr style="background:rgba(0,0,0,.25)">
                <th class="px-3 sm:px-4 py-2 text-left font-semibold" style="color:rgba(250,246,239,.6);font-family:'Plus Jakarta Sans',sans-serif">Swara</th>
                <th class="px-3 sm:px-4 py-2 text-left font-semibold" style="color:rgba(250,246,239,.6);font-family:'Plus Jakarta Sans',sans-serif">Hindi</th>
                <th class="px-3 sm:px-4 py-2 text-left font-semibold" style="color:rgba(250,246,239,.6);font-family:'Plus Jakarta Sans',sans-serif">Western</th>
                <th class="px-3 sm:px-4 py-2 text-left font-semibold" style="color:rgba(250,246,239,.6);font-family:'Plus Jakarta Sans',sans-serif">Key</th>
                <th class="px-3 sm:px-4 py-2 text-left font-semibold" style="color:rgba(250,246,239,.6);font-family:'Plus Jakarta Sans',sans-serif">Hz</th>
              </tr>
            </thead>
            <tbody>
              {[
                ['Sa','सा','C','A','261.63','white'],
                ['Re','रे','D','S','293.66','white'],
                ['Ga','ग','E','D','329.63','white'],
                ['Ma','म','F','F','349.23','white'],
                ['Pa','प','G','G','392.00','white'],
                ['Dha','ध','A','H','440.00','white'],
                ['Ni','नि','B','J','493.88','white'],
                ['Komal Re','ऋ','C#','W','277.18','black'],
                ['Komal Ga','ग॒','D#','E','311.13','black'],
                ['Tivra Ma','म॑','F#','T','369.99','black'],
                ['Komal Dha','ध॒','G#','Y','415.30','black'],
                ['Komal Ni','नि॒','A#','U','466.16','black'],
              ].map(([sw,hi,wes,k,hz,type],i)=>(
                <tr style={`${i%2===0?'background:rgba(0,0,0,.15)':'background:rgba(0,0,0,.08)'}`}>
                  <td class="px-3 sm:px-4 py-2 font-bold" style={`color:${type==='black'?'#d4920a':'#f0aa0e'};font-family:'Plus Jakarta Sans',sans-serif`}>{sw}</td>
                  <td class="px-3 sm:px-4 py-2" style="color:rgba(250,246,239,.8)">{hi}</td>
                  <td class="px-3 sm:px-4 py-2 font-mono" style="color:rgba(250,246,239,.7)">{wes}</td>
                  <td class="px-3 sm:px-4 py-2 font-mono" style="color:rgba(250,246,239,.5)">{k}</td>
                  <td class="px-3 sm:px-4 py-2" style="color:rgba(250,246,239,.35);font-family:'JetBrains Mono',monospace">{hz}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Alankar patterns -->
      <div class="mt-6 rounded-xl p-4 sm:p-5 border" style="background:rgba(255,255,255,.04);border-color:rgba(255,255,255,.08)">
        <h2 class="font-bold text-sm sm:text-base mb-4" style="color:#f0aa0e;font-family:'Plus Jakarta Sans',sans-serif">🔄 Quick Alankar Patterns</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {[
            {name:'Ascending Scale',  pat:'Sa Re Ga Ma Pa Dha Ni Ṡa', keys:'A  S  D  F  G  H   J  K'},
            {name:'Descending Scale', pat:'Ṡa Ni Dha Pa Ma Ga Re Sa',  keys:'K  J  H   G  F  D  S  A'},
            {name:'Pair Pattern',     pat:'SaRe ReGa GaMa MaPa PaDha', keys:'AS  SD   DF   FG   GH'},
            {name:'Triplet Pattern',  pat:'SaReGa ReGaMa GaMaPa …',    keys:'ASD  SDF   DFG   FGH'},
          ].map(a=>(
            <div class="rounded-lg p-3" style="background:rgba(0,0,0,.25)">
              <p class="font-semibold text-xs mb-1.5" style="color:rgba(250,246,239,.8);font-family:'Plus Jakarta Sans',sans-serif">{a.name}</p>
              <p class="font-mono text-xs sm:text-sm font-bold mb-1" style="color:#d4920a">{a.pat}</p>
              <p class="font-mono text-xs" style="color:rgba(250,246,239,.35)">Keys: {a.keys}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-8 text-center">
        <a href="/lessons" class="btn-primary inline-flex">📖 View Structured Lessons</a>
      </div>
    </div>
  </div>
</Layout>
