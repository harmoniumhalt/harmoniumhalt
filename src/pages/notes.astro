---
import Layout from '../layouts/Layout.astro';
const packs=[
  {t:'Complete Sargam Scale Chart',d:'All 12 scales in Indian sargam with Western equivalents.',p:'4 pages',cat:'Scales',icon:'🎼'},
  {t:'Popular Bhajans — Sargam Notations',d:'15 popular bhajans including Raghupati Raghav and Om Jai Jagdish.',p:'12 pages',cat:'Bhajans',icon:'🙏'},
  {t:'10 Essential Alankars',d:'Complete alankar guide with ascending/descending patterns.',p:'6 pages',cat:'Practice',icon:'🔄'},
  {t:'Raga Yaman — Complete Notes',d:'Full notation: aroha, avaroha, pakad, characteristic phrases.',p:'8 pages',cat:'Ragas',icon:'🌙'},
  {t:'Raga Bhairavi — Complete Notes',d:'Comprehensive notes with all characteristic phrases.',p:'8 pages',cat:'Ragas',icon:'🌅'},
  {t:'Beginner Harmonium Handbook',d:'Complete beginner reference: swaras, octaves, posture, first 5 songs.',p:'20 pages',cat:'Beginner',icon:'📗'},
  {t:'Bollywood Songs Collection',d:'Sargam notations for 10 popular Bollywood songs.',p:'15 pages',cat:'Songs',icon:'🎬'},
  {t:'Harmonium Fingering Chart',d:'Visual guide to finger placement for all common sequences.',p:'3 pages',cat:'Technique',icon:'👐'},
];
---
<Layout title="Free Harmonium Notes & PDF Downloads | Harmonium Halt"
  description="Download free harmonium notes PDF — sargam scale charts, bhajan notations, alankars, raga notes, and complete beginner handbook. All free.">
  <div class="bg-white border-b" style="border-color:rgba(28,16,8,.08)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-2.5 breadcrumb"><a href="/">Home</a><span class="mx-1.5">›</span><span>Notes & Downloads</span></div>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <div class="text-center mb-8 sm:mb-10">
      <h1 class="section-title text-3xl sm:text-4xl mb-3" style="color:#1c1008">Notes & Free Downloads</h1>
      <p class="text-sm sm:text-base mb-4 max-w-xl mx-auto" style="color:rgba(28,16,8,.55);font-family:'Plus Jakarta Sans',sans-serif">Download free harmonium practice notes, sargam charts, bhajan collections, and raga guides in PDF format.</p>
      <span class="inline-flex items-center gap-2 text-xs font-bold px-4 py-2 rounded-full" style="background:#dcfce7;color:#166534;border:1px solid #bbf7d0;font-family:'Plus Jakarta Sans',sans-serif">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        All downloads are completely free
      </span>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
      {packs.map(pk=>(
        <div class="bg-white rounded-2xl border overflow-hidden flex flex-col" style="border-color:rgba(28,16,8,.08)">
          <div class="h-1.5" style="background:linear-gradient(90deg,#c8360a,#d4920a)"></div>
          <div class="p-3 sm:p-4 flex flex-col flex-1">
            <div class="flex items-start justify-between mb-2 gap-2">
              <span class="text-2xl sm:text-3xl">{pk.icon}</span>
              <span class="text-xs px-2 py-0.5 rounded-full flex-shrink-0" style="background:#fef3c7;color:#92400e;font-family:'Plus Jakarta Sans',sans-serif">{pk.cat}</span>
            </div>
            <h3 class="font-bold text-xs sm:text-sm mb-1.5 leading-snug flex-1" style="color:#1c1008;font-family:'Plus Jakarta Sans',sans-serif">{pk.t}</h3>
            <p class="text-xs mb-3 leading-relaxed" style="color:rgba(28,16,8,.55);font-family:'Plus Jakarta Sans',sans-serif">{pk.d}</p>
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs" style="color:rgba(28,16,8,.35);font-family:'Plus Jakarta Sans',sans-serif">{pk.p}</span>
              <span class="text-xs font-bold" style="color:#166534;font-family:'Plus Jakarta Sans',sans-serif">FREE</span>
            </div>
            <button onclick="alert('PDF downloads coming soon! Check back shortly.')"
              class="w-full py-2 rounded-lg text-xs font-bold flex items-center justify-center gap-1.5 transition-all"
              style="background:#fef9f0;border:1px solid rgba(212,146,10,.3);color:#92400e;font-family:'Plus Jakarta Sans',sans-serif">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download PDF
            </button>
          </div>
        </div>
      ))}
    </div>
    <!-- Quick ref table -->
    <div class="mt-10 sm:mt-14">
      <h2 class="section-title text-2xl sm:text-3xl text-center mb-6" style="color:#1c1008">Quick Reference — All 12 Swaras</h2>
      <div class="bg-white rounded-2xl border overflow-hidden" style="border-color:rgba(28,16,8,.08)">
        <div class="table-wrap">
          <table class="w-full text-xs sm:text-sm" style="min-width:480px">
            <thead>
              <tr style="background:linear-gradient(90deg,#c8360a,#d4920a)">
                <th class="px-3 sm:px-4 py-3 text-left text-white font-semibold">Swara</th>
                <th class="px-3 sm:px-4 py-3 text-left text-white font-semibold">Hindi</th>
                <th class="px-3 sm:px-4 py-3 text-left text-white font-semibold">Western</th>
                <th class="px-3 sm:px-4 py-3 text-left text-white font-semibold">Type</th>
                <th class="px-3 sm:px-4 py-3 text-left text-white font-semibold">Hz</th>
              </tr>
            </thead>
            <tbody>
              {[
                ['Sa','सा','C','Achala','261.63'],['Komal Re','ऋ','C#','Komal','277.18'],
                ['Re','रे','D','Shuddha','293.66'],['Komal Ga','ग॒','D#','Komal','311.13'],
                ['Ga','ग','E','Shuddha','329.63'],['Ma','म','F','Shuddha','349.23'],
                ['Tivra Ma','म॑','F#','Tivra','369.99'],['Pa','प','G','Achala','392.00'],
                ['Komal Dha','ध॒','G#','Komal','415.30'],['Dha','ध','A','Shuddha','440.00'],
                ['Komal Ni','नि॒','A#','Komal','466.16'],['Ni','नि','B','Shuddha','493.88'],
              ].map(([sw,hi,wes,type,hz],i)=>(
                <tr style={`${i%2===0?'':'background:#fdf9f4'}`}>
                  <td class="px-3 sm:px-4 py-2.5 font-bold" style={`color:${type==='Komal'||type==='Tivra'?'#9e2808':'#c8360a'};font-family:'Plus Jakarta Sans',sans-serif`}>{sw}</td>
                  <td class="px-3 sm:px-4 py-2.5" style="color:#1c1008">{hi}</td>
                  <td class="px-3 sm:px-4 py-2.5 font-mono">{wes}</td>
                  <td class="px-3 sm:px-4 py-2.5">
                    <span class="text-xs px-2 py-0.5 rounded-full font-semibold" style={`${type==='Achala'?'background:#dbeafe;color:#1e40af':type==='Komal'?'background:#fee2e2;color:#991b1b':type==='Tivra'?'background:#dcfce7;color:#166534':'background:#fef3c7;color:#92400e'};font-family:'Plus Jakarta Sans',sans-serif`}>{type}</span>
                  </td>
                  <td class="px-3 sm:px-4 py-2.5 font-mono text-xs" style="color:rgba(28,16,8,.4)">{hz}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <div class="mt-8 text-center">
      <a href="/practice" class="btn-primary inline-flex">🎹 Practice on Web Harmonium</a>
    </div>
  </div>
</Layout>
