---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Harmonium Halt — Get in Touch"
  description="Contact the Harmonium Halt team. Send us your questions, feedback, or collaboration requests. We'd love to hear from harmonium learners."
>
  <div class="bg-white border-b border-ebony/8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-xs text-ebony/40">
      <a href="/" class="hover:text-saffron-600">Home</a>
      <span class="mx-2">›</span>
      <span class="text-ebony/70">Contact</span>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-10">
      <h1 class="font-display font-black text-4xl text-ebony mb-3">Contact Us</h1>
      <p class="text-ebony/60 text-lg max-w-xl mx-auto">Have a question, suggestion, or want to collaborate? We'd love to hear from you.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-10">
      <!-- Contact Form -->
      <div class="bg-white rounded-2xl border border-ebony/8 shadow-sm p-8">
        <h2 class="font-display font-bold text-xl text-ebony mb-6">Send a Message</h2>
        <form class="space-y-4" id="contact-form">
          <div>
            <label class="block text-sm font-medium text-ebony/70 mb-1" for="name">Your Name</label>
            <input type="text" id="name" name="name" required placeholder="Enter your name"
              class="w-full px-4 py-2.5 rounded-lg border border-ebony/15 text-sm focus:outline-none focus:ring-2 focus:ring-saffron-400 focus:border-transparent transition-all" />
          </div>
          <div>
            <label class="block text-sm font-medium text-ebony/70 mb-1" for="email">Email Address</label>
            <input type="email" id="email" name="email" required placeholder="your@email.com"
              class="w-full px-4 py-2.5 rounded-lg border border-ebony/15 text-sm focus:outline-none focus:ring-2 focus:ring-saffron-400 focus:border-transparent transition-all" />
          </div>
          <div>
            <label class="block text-sm font-medium text-ebony/70 mb-1" for="subject">Subject</label>
            <select id="subject" name="subject"
              class="w-full px-4 py-2.5 rounded-lg border border-ebony/15 text-sm focus:outline-none focus:ring-2 focus:ring-saffron-400 bg-white">
              <option>General Question</option>
              <option>Lesson Feedback</option>
              <option>Bug Report</option>
              <option>Content Suggestion</option>
              <option>Collaboration</option>
              <option>Other</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-ebony/70 mb-1" for="message">Message</label>
            <textarea id="message" name="message" required rows="5" placeholder="Write your message here..."
              class="w-full px-4 py-2.5 rounded-lg border border-ebony/15 text-sm focus:outline-none focus:ring-2 focus:ring-saffron-400 focus:border-transparent transition-all resize-none"></textarea>
          </div>
          <button type="submit"
            class="w-full bg-saffron-500 hover:bg-saffron-400 text-white font-bold py-3 rounded-xl transition-all shadow-lg shadow-saffron-500/20">
            Send Message →
          </button>
        </form>
        <p class="text-xs text-ebony/40 mt-3 text-center">We typically respond within 1–2 business days.</p>
      </div>

      <!-- Info -->
      <div class="space-y-6">
        <div class="bg-ivory rounded-2xl p-6 border border-ebony/6">
          <h2 class="font-display font-bold text-xl text-ebony mb-4">Contact Information</h2>
          <div class="space-y-4">
            {[
              { icon: '📧', label: 'Email', value: 'hello@harmoniumhalt.com' },
              { icon: '🌐', label: 'Website', value: 'www.harmoniumhalt.com' },
              { icon: '📍', label: 'Based in', value: 'India' },
            ].map(c => (
              <div class="flex gap-3 items-start">
                <span class="text-lg">{c.icon}</span>
                <div>
                  <p class="text-xs text-ebony/40 font-medium">{c.label}</p>
                  <p class="text-sm text-ebony font-medium">{c.value}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-saffron-50 border border-saffron-200 rounded-2xl p-6">
          <h3 class="font-display font-bold text-saffron-800 mb-3">💡 Common Questions</h3>
          <div class="space-y-3 text-sm text-saffron-700">
            {[
              { q: 'Is Harmonium Halt really free?', a: 'Yes — all lessons, tools, and content are 100% free.' },
              { q: 'Can I request a specific lesson topic?', a: 'Absolutely! Use the contact form with subject "Content Suggestion".' },
              { q: 'I found a bug on the web harmonium.', a: 'Please report it via the contact form. We fix bugs quickly!' },
            ].map(faq => (
              <div>
                <p class="font-semibold">{faq.q}</p>
                <p class="text-saffron-600">{faq.a}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('contact-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      if (btn) {
        btn.textContent = '✓ Message Sent!';
        btn.classList.replace('bg-saffron-500', 'bg-green-500');
        btn.classList.replace('hover:bg-saffron-400', 'hover:bg-green-400');
        btn.disabled = true;
      }
    });
  </script>
</Layout>
