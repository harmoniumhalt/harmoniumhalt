---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms of Use | Harmonium Halt" description="Terms and conditions for using Harmonium Halt website and services." noindex={false}>
  <div class="bg-white border-b border-ebony/8">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-xs text-ebony/40">
      <a href="/" class="hover:text-saffron-600">Home</a><span class="mx-2">›</span><span class="text-ebony/70">Terms of Use</span>
    </div>
  </div>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
