---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page Not Found — Harmonium Halt" noindex={true}>
  <div class="min-h-screen flex items-center justify-center text-center px-4" style="background:linear-gradient(135deg,#1c1008,#3d1a08)">
    <div>
      <div class="text-5xl sm:text-6xl mb-4">🎹</div>
      <h1 class="section-title text-4xl sm:text-5xl mb-3" style="color:#faf6ef">404</h1>
      <p class="text-base sm:text-xl mb-2" style="color:rgba(250,246,239,.6);font-family:'Plus Jakarta Sans',sans-serif">This note doesn't exist in our scale.</p>
      <p class="text-sm mb-8" style="color:rgba(250,246,239,.35);font-family:'Plus Jakarta Sans',sans-serif">The page has been moved or never existed.</p>
      <div class="flex flex-col xs:flex-row gap-3 justify-center">
        <a href="/" class="btn-primary justify-center">← Go Home</a>
        <a href="/lessons" class="btn-secondary justify-center">View Lessons</a>
      </div>
    </div>
  </div>
</Layout>
