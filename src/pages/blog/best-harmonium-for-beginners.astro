              <span class="text-sm font-semibold text-saffron-600">{h.price}</span>
            </div>
            <div class="text-gold-500">{'★'.repeat(h.rating)}{'☆'.repeat(5 - h.rating)}</div>
          </div>
          <div class="p-5 grid sm:grid-cols-2 gap-4">
            <div>
