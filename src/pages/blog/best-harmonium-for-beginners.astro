          rating: 3,
        },
      ].map(h => (
        <div class="bg-white border border-ebony/10 rounded-xl overflow-hidden shadow-sm my-5">
          <div class="flex items-center gap-3 px-5 py-3 bg-gradient-to-r from-saffron-50 to-ivory border-b border-ebony/6">
