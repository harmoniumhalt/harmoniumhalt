---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';

const articles = [
  { title: 'How to Learn Harmonium at Home: Complete Beginner Guide 2024', description: 'A step-by-step guide to learning harmonium from scratch at home. No teacher needed. Includes free resources and practice schedule.', href: '/blog/learn-harmonium-at-home', date: 'December 10, 2024', category: 'Beginner', readTime: '8 min read' },
  { title: 'Best Harmonium for Beginners in India 2024 — Top 10 Reviewed', description: 'Detailed reviews of the best harmoniums available in India for beginners. Includes budget options, brand comparisons, and buying tips.', href: '/blog/best-harmonium-for-beginners', date: 'December 5, 2024', category: 'Buying Guide', readTime: '10 min read' },
  { title: 'Sa Re Ga Ma Pa — Complete Guide to Indian Sargam', description: 'Master the seven swaras of Indian classical music. Understand komal, tivra, and how sargam notation works.', href: '/blog/sa-re-ga-ma-pa-guide', date: 'December 1, 2024', category: 'Theory', readTime: '12 min read' },
  { title: 'Top 10 Bhajans to Learn on Harmonium (With Notes)', description: 'Step-by-step harmonium notes for 10 popular bhajans. Includes Raghupati Raghav, Om Jai Jagdish Hare, and more.', href: '/blog/bhajans-on-harmonium', date: 'November 28, 2024', category: 'Songs & Bhajans', readTime: '15 min read' },
  { title: 'What is a Raga? Complete Explanation for Beginners', description: 'A clear, beginner-friendly explanation of what ragas are, how they work, and why they are the heart of Indian classical music.', href: '/blog/what-is-a-raga', date: 'November 22, 2024', category: 'Theory', readTime: '9 min read' },
  { title: 'Harmonium vs Keyboard: Which Should You Learn First?', description: 'Detailed comparison of harmonium and electronic keyboard for Indian music learners. Pros, cons, and our recommendation.', href: '/blog/harmonium-vs-keyboard', date: 'November 18, 2024', category: 'Comparison', readTime: '7 min read' },
  { title: 'Raga Yaman on Harmonium — Complete Lesson with Notes', description: 'Learn Raga Yaman completely. Aroha, avaroha, characteristic phrases, and a simple composition with sargam notes.', href: '/blog/raga-yaman-harmonium', date: 'November 12, 2024', category: 'Ragas', readTime: '14 min read' },
  { title: '10 Alankars Every Harmonium Student Must Practice', description: 'The 10 essential alankars (practice patterns) with sargam notation and tips for mastering them systematically.', href: '/blog/alankars-for-harmonium', date: 'November 8, 2024', category: 'Practice', readTime: '11 min read' },
  { title: 'History of Harmonium in India — From Europe to Bhakti', description: 'The fascinating journey of harmonium from 19th century Europe to becoming integral to Indian classical and devotional music.', href: '/blog/harmonium-history-india', date: 'November 2, 2024', category: 'History', readTime: '8 min read' },
  { title: 'How to Tune a Harmonium: Step-by-Step Guide', description: 'Learn to tune your harmonium reeds at home. Tools needed, process explained, common tuning problems and solutions.', href: '/blog/how-to-tune-harmonium', date: 'October 28, 2024', category: 'Maintenance', readTime: '10 min read' },
  { title: 'Harmonium Maintenance Tips — Keep Your Instrument in Perfect Condition', description: 'Essential maintenance tips for harmonium owners. Cleaning, storage, reed care, and when to take it to a repair shop.', href: '/blog/harmonium-maintenance', date: 'October 22, 2024', category: 'Maintenance', readTime: '7 min read' },
  { title: 'Raga Bhairavi — The Queen of All Ragas', description: 'Deep exploration of Raga Bhairavi — its emotional quality, time of performance, characteristic phrases, and how to play it.', href: '/blog/raga-bhairavi-guide', date: 'October 16, 2024', category: 'Ragas', readTime: '12 min read' },
  { title: 'Morning Ragas vs Evening Ragas — Complete Guide', description: 'Why do some ragas sound better in the morning? Complete explanation of raga time theory with examples.', href: '/blog/morning-evening-ragas', date: 'October 10, 2024', category: 'Theory', readTime: '9 min read' },
  { title: 'Harmonium for Kirtan: Techniques and Tips', description: 'Master the art of harmonium playing for kirtan and bhajan sessions. Drone, melody, and energy-building techniques.', href: '/blog/harmonium-for-kirtan', date: 'October 5, 2024', category: 'Practice', readTime: '8 min read' },
  { title: 'How Long Does It Take to Learn Harmonium?', description: 'Realistic timeline for learning harmonium at different levels. With tips for faster progress and common pitfalls to avoid.', href: '/blog/how-long-to-learn-harmonium', date: 'September 28, 2024', category: 'Beginner', readTime: '6 min read' },
  { title: 'Free Harmonium Notes PDF — Download All Scales & Bhajans', description: 'Download free PDF notes for harmonium — all 12 scales, popular bhajans, alankars, and ragas in sargam notation.', href: '/blog/free-harmonium-notes-pdf', date: 'September 22, 2024', category: 'Downloads', readTime: '5 min read' },
  { title: 'Harmonium Parts and Their Functions Explained', description: 'Complete guide to harmonium anatomy — bellows, reeds, keys, stops, drone — with diagrams and explanations.', href: '/blog/harmonium-parts-functions', date: 'September 16, 2024', category: 'Beginner', readTime: '8 min read' },
  { title: 'Playing Bollywood Songs on Harmonium — 5 Popular Songs', description: 'Learn to play 5 popular Bollywood songs on harmonium with complete sargam notation.', href: '/blog/bollywood-songs-harmonium', date: 'September 10, 2024', category: 'Songs & Bhajans', readTime: '12 min read' },
  { title: 'What is Shruti Box? Harmonium vs Shruti Box', description: 'Understanding the difference between harmonium and shruti box. When to use each and how they complement Indian singing.', href: '/blog/harmonium-vs-shruti-box', date: 'September 3, 2024', category: 'Comparison', readTime: '7 min read' },
  { title: 'Raga Bhairav — The Divine Morning Raga', description: 'Master Raga Bhairav — its serious, devotional mood, all komal swaras, characteristic movements, and popular compositions.', href: '/blog/raga-bhairav-guide', date: 'August 26, 2024', category: 'Ragas', readTime: '13 min read' },
  { title: 'Indian Classical Music Terminology: Glossary for Beginners', description: 'A comprehensive A-Z glossary of Indian classical music terms that every harmonium student needs to know.', href: '/blog/indian-music-terminology', date: 'August 20, 2024', category: 'Theory', readTime: '15 min read' },
  { title: 'Harmonium Scale Chart — All 12 Scales with Sargam', description: 'Complete harmonium scale chart with all 12 major and minor scales in Indian sargam notation. Perfect for practice.', href: '/blog/harmonium-scale-chart', date: 'August 14, 2024', category: 'Practice', readTime: '8 min read' },
  { title: 'Daily Riyaaz Routine for Harmonium Students', description: '30-minute structured daily practice routine for harmonium. Week-by-week progressive plan for consistent improvement.', href: '/blog/daily-riyaaz-routine', date: 'August 7, 2024', category: 'Practice', readTime: '9 min read' },
  { title: 'How to Read Sargam Notation — Complete Tutorial', description: 'Step-by-step tutorial for reading sargam notation. Symbols, numbers, lines, and dots explained with examples.', href: '/blog/read-sargam-notation', date: 'July 30, 2024', category: 'Theory', readTime: '11 min read' },
  { title: 'Harmonium Lessons Online vs In-Person: Which is Better?', description: 'Honest comparison of online vs offline harmonium learning. Cost, convenience, effectiveness, and our recommendation.', href: '/blog/harmonium-lessons-online-vs-offline', date: 'July 22, 2024', category: 'Beginner', readTime: '7 min read' },
];

const categories = ['All', 'Beginner', 'Theory', 'Ragas', 'Songs & Bhajans', 'Practice', 'Maintenance', 'Buying Guide', 'History', 'Comparison', 'Downloads'];
---

<Layout
  title="Harmonium Blog — Tips, Lessons & Guides | Harmonium Halt"
  description="Free harmonium articles, lessons, and guides. Learn about ragas, bhajans, practice techniques, buying guides, and more. Expert content for harmonium learners."
>
  <div class="bg-white border-b border-ebony/8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-xs text-ebony/40">
      <a href="/" class="hover:text-saffron-600">Home</a>
      <span class="mx-2">›</span>
      <span class="text-ebony/70">Blog</span>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-10">
      <h1 class="font-display font-black text-4xl md:text-5xl text-ebony mb-4">Harmonium Blog</h1>
      <p class="text-xl text-ebony/60 max-w-2xl mx-auto">Expert articles, lesson guides, and tips for harmonium learners of all levels.</p>
    </div>

    <!-- Category pills -->
    <div class="flex flex-wrap gap-2 justify-center mb-10">
      {categories.map((cat, i) => (
        <span class={`px-3 py-1.5 rounded-full text-xs font-semibold cursor-pointer transition-all ${i === 0 ? 'bg-saffron-500 text-white' : 'bg-ebony/5 text-ebony/60 hover:bg-ebony/10'}`}>
          {cat}
        </span>
      ))}
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {articles.map(a => <BlogCard {...a} />)}
    </div>
  </div>
</Layout>
