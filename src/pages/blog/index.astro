---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';

const articles = [
  {title:'How to Learn Harmonium at Home: Complete Guide 2024',description:'Step-by-step guide to self-teaching harmonium from scratch. No teacher needed.',href:'/blog/learn-harmonium-at-home',date:'Dec 10, 2024',category:'Beginner',readTime:'8 min'},
  {title:'Best Harmonium for Beginners in India 2024 — Top 10',description:'Detailed reviews of the best harmoniums for Indian beginners at every budget.',href:'/blog/best-harmonium-for-beginners',date:'Dec 5, 2024',category:'Buying Guide',readTime:'10 min'},
  {title:'Sa Re Ga Ma Pa — Complete Guide to Indian Sargam',description:'Master the seven swaras, komal/tivra notes, and sargam notation system.',href:'/blog/sa-re-ga-ma-pa-guide',date:'Dec 1, 2024',category:'Theory',readTime:'12 min'},
  {title:'Top 10 Bhajans to Learn on Harmonium (With Notes)',description:'Sargam notations for 10 popular bhajans including Raghupati Raghav.',href:'/blog/bhajans-on-harmonium',date:'Nov 28, 2024',category:'Songs',readTime:'15 min'},
  {title:'What is a Raga? Complete Explanation for Beginners',description:'A clear, beginner-friendly explanation of ragas in Indian classical music.',href:'/blog/what-is-a-raga',date:'Nov 22, 2024',category:'Theory',readTime:'9 min'},
  {title:'Harmonium vs Keyboard: Which Should You Learn First?',description:'Detailed comparison for Indian music learners. Pros, cons, and our pick.',href:'/blog/harmonium-vs-keyboard',date:'Nov 18, 2024',category:'Comparison',readTime:'7 min'},
  {title:'Raga Yaman on Harmonium — Complete Lesson with Notes',description:'Learn Raga Yaman completely with aroha, avaroha, pakad, and bandish.',href:'/blog/raga-yaman-harmonium',date:'Nov 12, 2024',category:'Ragas',readTime:'14 min'},
  {title:'10 Alankars Every Harmonium Student Must Practice',description:'The 10 essential alankars with sargam notation and practice tips.',href:'/blog/alankars-for-harmonium',date:'Nov 8, 2024',category:'Practice',readTime:'11 min'},
  {title:'History of Harmonium in India — From Europe to Bhakti',description:'The journey of harmonium from 19th century Europe to Indian devotional music.',href:'/blog/harmonium-history-india',date:'Nov 2, 2024',category:'History',readTime:'8 min'},
  {title:'How to Tune a Harmonium: Step-by-Step Guide',description:'Tune your harmonium reeds at home. Tools, process, and common problems.',href:'/blog/how-to-tune-harmonium',date:'Oct 28, 2024',category:'Maintenance',readTime:'10 min'},
  {title:'Harmonium Maintenance Tips — Complete Care Guide',description:'Cleaning, storage, reed care, and when to take it to a repair shop.',href:'/blog/harmonium-maintenance',date:'Oct 22, 2024',category:'Maintenance',readTime:'7 min'},
  {title:'Raga Bhairavi — The Queen of All Ragas',description:'Deep exploration of Raga Bhairavi — mood, phrases, and how to play it.',href:'/blog/raga-bhairavi-guide',date:'Oct 16, 2024',category:'Ragas',readTime:'12 min'},
  {title:'Morning Ragas vs Evening Ragas — Complete Guide',description:'Why some ragas sound better at specific times. Raga time theory explained.',href:'/blog/morning-evening-ragas',date:'Oct 10, 2024',category:'Theory',readTime:'9 min'},
  {title:'Harmonium for Kirtan: Techniques and Tips',description:'Master drone, melody, and energy-building for kirtan sessions.',href:'/blog/harmonium-for-kirtan',date:'Oct 5, 2024',category:'Practice',readTime:'8 min'},
  {title:'How Long Does It Take to Learn Harmonium?',description:'Realistic timeline with tips for faster progress and common pitfalls.',href:'/blog/how-long-to-learn-harmonium',date:'Sep 28, 2024',category:'Beginner',readTime:'6 min'},
  {title:'Free Harmonium Notes PDF — All Scales & Bhajans',description:'Download free PDF notes for scales, popular bhajans, alankars, and ragas.',href:'/blog/free-harmonium-notes-pdf',date:'Sep 22, 2024',category:'Downloads',readTime:'5 min'},
  {title:'Harmonium Parts and Their Functions Explained',description:'Complete guide to harmonium anatomy — bellows, reeds, keys, stops, drone.',href:'/blog/harmonium-parts-functions',date:'Sep 16, 2024',category:'Beginner',readTime:'8 min'},
  {title:'Playing Bollywood Songs on Harmonium — 5 Songs',description:'Learn 5 popular Bollywood songs with complete sargam notation.',href:'/blog/bollywood-songs-harmonium',date:'Sep 10, 2024',category:'Songs',readTime:'12 min'},
  {title:'Harmonium vs Shruti Box — What\'s the Difference?',description:'When to use each and how they complement Indian singing.',href:'/blog/harmonium-vs-shruti-box',date:'Sep 3, 2024',category:'Comparison',readTime:'7 min'},
  {title:'Raga Bhairav — The Divine Morning Raga',description:'Master Raga Bhairav — devotional mood, komal swaras, popular compositions.',href:'/blog/raga-bhairav-guide',date:'Aug 26, 2024',category:'Ragas',readTime:'13 min'},
  {title:'Indian Classical Music Terminology: A–Z Glossary',description:'Comprehensive glossary of Indian music terms every harmonium student needs.',href:'/blog/indian-music-terminology',date:'Aug 20, 2024',category:'Theory',readTime:'15 min'},
  {title:'Harmonium Scale Chart — All 12 Scales with Sargam',description:'Complete scale chart with all 12 major and minor scales for practice.',href:'/blog/harmonium-scale-chart',date:'Aug 14, 2024',category:'Practice',readTime:'8 min'},
  {title:'Daily Riyaaz Routine for Harmonium Students',description:'30-minute structured daily practice plan with week-by-week progression.',href:'/blog/daily-riyaaz-routine',date:'Aug 7, 2024',category:'Practice',readTime:'9 min'},
  {title:'How to Read Sargam Notation — Complete Tutorial',description:'Symbols, numbers, lines, and dots — sargam reading explained with examples.',href:'/blog/read-sargam-notation',date:'Jul 30, 2024',category:'Theory',readTime:'11 min'},
  {title:'Online vs In-Person Harmonium Lessons: Which is Better?',description:'Honest comparison of online vs offline learning — cost, effectiveness, tips.',href:'/blog/harmonium-lessons-online-vs-offline',date:'Jul 22, 2024',category:'Beginner',readTime:'7 min'},
];

const cats = ['All','Beginner','Theory','Ragas','Songs','Practice','Maintenance','Buying Guide','History','Comparison','Downloads'];
---

<Layout title="Harmonium Blog — Tips, Lessons & Guides | Harmonium Halt"
  description="Free harmonium articles, lessons, and guides. Ragas, bhajans, practice techniques, buying guides, and more. Expert content for all levels.">

  <!-- Breadcrumb -->
  <div class="bg-white border-b" style="border-color:rgba(28,16,8,.08)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <nav class="breadcrumb"><a href="/">Home</a><span class="mx-1.5">›</span><span>Blog</span></nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">

    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="section-title text-3xl sm:text-4xl lg:text-5xl mb-3" style="color:#1c1008">Harmonium Blog</h1>
      <p class="text-sm sm:text-base max-w-xl mx-auto" style="color:rgba(28,16,8,.55);font-family:'Plus Jakarta Sans',sans-serif">Expert articles, lesson guides, and tips for harmonium learners of all levels.</p>
    </div>

    <!-- Category pills - scrollable on mobile -->
    <div class="flex gap-2 overflow-x-auto pb-2 mb-8 -mx-4 px-4 sm:mx-0 sm:px-0 sm:flex-wrap sm:justify-center"
         style="-webkit-overflow-scrolling:touch;scrollbar-width:none">
      {cats.map((c,i)=>(
        <button class="flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-bold transition-all border"
                style={i===0
                  ? 'background:#c8360a;color:#fff;border-color:#c8360a;font-family:"Plus Jakarta Sans",sans-serif'
                  : 'background:#fff;color:rgba(28,16,8,.6);border-color:rgba(28,16,8,.15);font-family:"Plus Jakarta Sans",sans-serif'}
                data-cat={c}>
          {c}
        </button>
      ))}
    </div>

    <!-- Articles grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="blog-grid">
      {articles.map(a=><BlogCard {...a}/>)}
    </div>

  </div>
</Layout>
