---
import Layout from '../../layouts/Layout.astro';
import Harmonium from '../../components/Harmonium.astro';
---

<Layout
  title="Alankars for Harmonium — 10 Essential Practice Patterns | Harmonium Halt"
  description="Learn 10 essential alankars for harmonium practice. Daily patterns to build speed, accuracy, and muscle memory. Includes keyboard shortcuts and practice tips."
>
  <div class="bg-white border-b border-ebony/8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-xs text-ebony/40">
      <a href="/" class="hover:text-saffron-600">Home</a><span class="mx-2">›</span>
      <a href="/lessons" class="hover:text-saffron-600">Lessons</a><span class="mx-2">›</span>
      <span class="text-ebony/70">Alankars</span>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class="text-xs font-semibold bg-saffron-100 text-saffron-700 px-3 py-1 rounded-full">Intermediate</span>
        <span class="text-xs text-ebony/40">⏱ 30 min</span>
      </div>
      <h1 class="font-display font-black text-4xl text-ebony mb-3">Alankars — 10 Essential Practice Patterns</h1>
      <p class="text-xl text-ebony/60 leading-relaxed">Alankars are structured practice patterns that build finger speed, independence, and coordination. These are the core of daily <em>riyaaz</em> (practice) for every harmonium student.</p>
    </div>

    <div class="bg-saffron-50 border border-saffron-200 rounded-xl p-5 mb-8">
      <h3 class="font-bold text-saffron-800 mb-2">What is an Alankar?</h3>
      <p class="text-sm text-saffron-700">The word <em>alankar</em> comes from Sanskrit meaning "ornament" or "decoration." In practice, alankars are systematic sequences that move through the saptaka (octave) in a fixed pattern. Regular alankar practice is the single most effective thing you can do to improve your harmonium playing.</p>
    </div>

    <div class="prose-harmonium">
      <h2>How to Practice Alankars</h2>
      <ul>
        <li>Start very slowly — slower than you think you need to</li>
        <li>Use a metronome or tabla track at 60 BPM initially</li>
        <li>Each note should be equal in duration and volume</li>
        <li>Increase speed only when the pattern feels completely natural</li>
        <li>Practice each alankar ascending and descending</li>
      </ul>
    </div>

    <!-- The 10 Alankars -->
    <div class="mt-8 space-y-5">
      <h2 class="font-display font-bold text-2xl text-ebony">The 10 Alankars</h2>
      {[
        {
          num: 1, name: 'Ascending Scale',
          sargam: 'S R G M P D N Ṡ',
          keys: 'A S D F G H J K',
          desc: 'The foundation. Play each swara clearly and evenly. This trains even finger pressure and basic coordination.',
        },
        {
          num: 2, name: 'Descending Scale',
          sargam: 'Ṡ N D P M G R S',
          keys: 'K J H G F D S A',
          desc: 'The reverse of Alankar 1. Many beginners find descending harder — focus extra attention here.',
        },
        {
          num: 3, name: 'Pairs Ascending',
          sargam: 'SR RG GM MP PD DN NṠ',
          keys: 'AS SD DF FG GH HJ JK',
          desc: 'Two consecutive swaras played as a unit. Builds smooth finger transitions.',
        },
        {
          num: 4, name: 'Pairs Descending',
          sargam: 'ṠN ND DP PM MG GR RS',
          keys: 'KJ JH HG GF FD DS SA',
          desc: 'Descending version of Alankar 3.',
        },
        {
          num: 5, name: 'Triplets Ascending',
          sargam: 'SRG RGM GMP MPD PDN DNṠ',
          keys: 'ASD SDF DFG FGH GHJ HJK',
          desc: 'Three-note groups. This is where speed and coordination really begin to develop.',
        },
        {
          num: 6, name: 'Triplets Descending',
          sargam: 'ṠND NDP DPM PMG MGR GRS',
          keys: 'KJH JHG HGF GFD FDS DSA',
          desc: 'Descending triplets. Practice this at the same tempo as Alankar 5.',
        },
        {
          num: 7, name: 'Tetrachords',
          sargam: 'SRGM RGMP GMPD MPDM PDNṠr',
          keys: 'ASDF SDFG DFGH FGHJ GHJK',
          desc: 'Four-note groups. One of the most important alankars for building true playing speed.',
        },
        {
          num: 8, name: 'Skip Pattern (Sa-Ga)',
          sargam: 'S G R M G P M D P N D Ṡ',
          keys: 'A D S F D G F H G J H K',
          desc: 'Skipping every other note — trains finger independence and expands keyboard familiarity.',
        },
        {
          num: 9, name: 'Turn Pattern',
          sargam: 'SRS RGR GMG MPM PDPDDNṠNṠ',
          keys: 'ASA SDS DFD FGF GHG HJH JKJ',
          desc: 'Moving forward and backward like a turn/trill. Develops fine motor control.',
        },
        {
          num: 10, name: 'Full Octave Jump',
          sargam: 'S Ṡ R Ṙ G Ġ M Ṁ P Ṗ D Ḋ N Ṅ',
          keys: 'A K  S L  D ;',
          desc: 'Playing each swara and its upper octave equivalent. Develops large position jumps and octave awareness.',
        },
      ].map(a => (
        <div class="bg-white border border-ebony/8 rounded-xl overflow-hidden shadow-sm">
          <div class="flex items-center gap-4 px-5 py-3 bg-gradient-to-r from-saffron-50 to-ivory border-b border-ebony/6">
            <div class="w-8 h-8 bg-saffron-500 text-white rounded-lg flex items-center justify-center font-bold text-sm flex-shrink-0">{a.num}</div>
            <h3 class="font-display font-bold text-ebony">{a.name}</h3>
          </div>
          <div class="p-5">
            <div class="mb-3">
              <p class="text-xs text-ebony/40 uppercase tracking-wider mb-1">Sargam Pattern</p>
              <p class="font-mono text-saffron-700 font-bold text-lg tracking-wider">{a.sargam}</p>
            </div>
            <div class="mb-3">
              <p class="text-xs text-ebony/40 uppercase tracking-wider mb-1">Keyboard Keys</p>
              <p class="font-mono text-ebony/60 bg-ebony/5 px-3 py-1 rounded-lg text-sm inline-block">{a.keys}</p>
            </div>
            <p class="text-sm text-ebony/70 leading-relaxed">{a.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Practice Harmonium -->
    <div class="mt-10 mb-8">
      <h2 class="font-display font-bold text-2xl text-ebony mb-4">Practice Alankars Now</h2>
      <div class="bg-gradient-to-br from-ebony to-wood-dark p-6 rounded-2xl">
        <Harmonium />
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-between">
      <a href="/lessons/finger-placement" class="flex items-center gap-2 text-sm text-ebony/50 hover:text-ebony">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Previous: Finger Placement
      </a>
      <a href="/lessons/ragas-introduction" class="flex items-center gap-2 bg-saffron-500 hover:bg-saffron-400 text-white font-bold px-6 py-3 rounded-xl transition-all">
        Next: Ragas Intro →
      </a>
    </div>
  </div>
</Layout>
