---
import Layout from '../../layouts/Layout.astro';
import LessonCard from '../../components/LessonCard.astro';

const beginner = [
  {title:'Introduction to Harmonium',description:'Parts, history, and your very first sounds.',href:'/lessons/introduction-to-harmonium',level:'beginner',duration:'10 min',icon:'🎹'},
  {title:'Understanding the Keyboard',description:'White keys, black keys, octaves explained.',href:'/lessons/understanding-the-keyboard',level:'beginner',duration:'15 min',icon:'⌨️'},
  {title:'Sa Re Ga Ma — Seven Swaras',description:'India\'s musical alphabet from Sa to Ni.',href:'/lessons/sa-re-ga-ma',level:'beginner',duration:'20 min',icon:'🎵'},
  {title:'Finger Placement & Posture',description:'Correct technique to avoid strain and build speed.',href:'/lessons/finger-placement',level:'beginner',duration:'15 min',icon:'👐'},
  {title:'Komal and Tivra Swaras',description:'Black keys explained — flat and sharp notes.',href:'/lessons/komal-tivra-swaras',level:'beginner',duration:'20 min',icon:'🎼'},
  {title:'Sargam Notation Reading',description:'Learn to read and write India\'s sheet music.',href:'/lessons/sargam-notation',level:'beginner',duration:'20 min',icon:'📝'},
  {title:'Playing Bhajans',description:'Play popular devotional songs with notations.',href:'/lessons/bhajans',level:'beginner',duration:'25 min',icon:'🙏'},
  {title:'Major Scales Practice',description:'All 12 major scales ascending and descending.',href:'/lessons/major-scales',level:'beginner',duration:'20 min',icon:'📈'},
];
const intermediate = [
  {title:'Alankars — 10 Essential Patterns',description:'Daily practice patterns for speed and coordination.',href:'/lessons/alankars',level:'intermediate',duration:'30 min',icon:'🔄'},
  {title:'Introduction to Ragas',description:'Aroha, avaroha, vadi, samvadi, and time theory.',href:'/lessons/ragas-introduction',level:'intermediate',duration:'25 min',icon:'🌙'},
  {title:'Raga Yaman',description:'Learn the most popular evening raga completely.',href:'/lessons/raga-yaman',level:'intermediate',duration:'40 min',icon:'⭐'},
  {title:'Raga Bhairavi',description:'The most beloved morning raga, all komal swaras.',href:'/lessons/raga-bhairavi',level:'intermediate',duration:'40 min',icon:'🌅'},
  {title:'Harmonium Chords',description:'Major, minor, and seventh chords for accompaniment.',href:'/lessons/harmonium-chords',level:'intermediate',duration:'30 min',icon:'🎸'},
  {title:'Taal and Rhythm',description:'Teentaal, Ektaal, Keherwa — rhythmic framework.',href:'/lessons/taal-rhythm',level:'intermediate',duration:'35 min',icon:'🥁'},
];
const advanced = [
  {title:'Classical Improvisation',description:'Gamak, meend, andolan — raga ornaments.',href:'/lessons/classical-improvisation',level:'advanced',duration:'45 min',icon:'🌟'},
  {title:'Raga Bhairav — Deep Study',description:'The majestic morning raga with compositions.',href:'/lessons/raga-bhairav',level:'advanced',duration:'50 min',icon:'🏔️'},
  {title:'Bandish and Composition',description:'Classical compositions in Drut and Vilambit.',href:'/lessons/bandish-composition',level:'advanced',duration:'45 min',icon:'🎭'},
  {title:'Harmonium for Kirtan',description:'Advanced techniques for leading kirtan sessions.',href:'/lessons/kirtan-techniques',level:'advanced',duration:'40 min',icon:'🕉️'},
];
const practice = [
  {title:'Daily Riyaaz Routine',description:'30-minute structured daily practice plan.',href:'/lessons/daily-riyaaz',level:'practice',duration:'30 min',icon:'⏰'},
  {title:'Speed Building Exercises',description:'Targeted exercises to increase playing speed.',href:'/lessons/speed-exercises',level:'practice',duration:'20 min',icon:'⚡'},
  {title:'Ear Training for Swaras',description:'Identify swaras by sound — essential for ragas.',href:'/lessons/ear-training',level:'practice',duration:'25 min',icon:'👂'},
];
---

<Layout title="Harmonium Lessons — Beginner to Advanced | Harmonium Halt"
  description="Free harmonium lessons for all levels. Beginner to advanced curriculum covering Sa Re Ga Ma, alankars, ragas, bhajans, and classical techniques.">

  <!-- Breadcrumb -->
  <div class="bg-white border-b" style="border-color:rgba(28,16,8,.08)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <nav class="breadcrumb">
        <a href="/">Home</a><span class="mx-1.5">›</span><span>Lessons</span>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">

    <!-- Header -->
    <div class="text-center mb-8 sm:mb-12">
      <h1 class="section-title text-3xl sm:text-4xl lg:text-5xl mb-3" style="color:#1c1008">Harmonium Lessons</h1>
      <p class="text-sm sm:text-lg max-w-xl mx-auto" style="color:rgba(28,16,8,.55);font-family:'Plus Jakarta Sans',sans-serif">
        Complete learning path from absolute beginner to advanced performer. All lessons are free.
      </p>
    </div>

    <!-- Level jump links -->
    <div class="flex flex-wrap gap-2 justify-center mb-10">
      {[
        {href:'#beginner',     label:'🟢 Beginner',      cls:'border-green-300  text-green-800  bg-green-50'},
        {href:'#intermediate', label:'🟡 Intermediate',   cls:'border-yellow-300 text-yellow-800 bg-yellow-50'},
        {href:'#advanced',     label:'🔴 Advanced',       cls:'border-red-300    text-red-800    bg-red-50'},
        {href:'#practice',     label:'⭐ Practice',       cls:'border-amber-300  text-amber-800  bg-amber-50'},
      ].map(l=>(
        <a href={l.href} class={`px-3 sm:px-4 py-1.5 rounded-full border-2 font-bold text-xs sm:text-sm transition-all hover:shadow-md ${l.cls}`}
           style="font-family:'Plus Jakarta Sans',sans-serif;text-decoration:none">{l.label}</a>
      ))}
    </div>

    <!-- Beginner -->
    <section id="beginner" class="mb-12 sm:mb-14">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-3 h-3 rounded-full bg-green-500 flex-shrink-0"></div>
        <h2 class="font-display font-bold text-xl sm:text-2xl" style="color:#1c1008">Beginner Lessons</h2>
        <span class="badge badge-beginner">{beginner.length} lessons</span>
      </div>
      <div class="grid grid-cols-1 xs:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        {beginner.map(l=><LessonCard {...l} level="beginner"/>)}
      </div>
    </section>

    <!-- Intermediate -->
    <section id="intermediate" class="mb-12 sm:mb-14">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-3 h-3 rounded-full bg-yellow-500 flex-shrink-0"></div>
        <h2 class="font-display font-bold text-xl sm:text-2xl" style="color:#1c1008">Intermediate Lessons</h2>
        <span class="badge badge-intermediate">{intermediate.length} lessons</span>
      </div>
      <div class="grid grid-cols-1 xs:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
        {intermediate.map(l=><LessonCard {...l} level="intermediate"/>)}
      </div>
    </section>

    <!-- Advanced -->
    <section id="advanced" class="mb-12 sm:mb-14">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-3 h-3 rounded-full bg-red-500 flex-shrink-0"></div>
        <h2 class="font-display font-bold text-xl sm:text-2xl" style="color:#1c1008">Advanced Lessons</h2>
        <span class="badge badge-advanced">{advanced.length} lessons</span>
      </div>
      <div class="grid grid-cols-1 xs:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        {advanced.map(l=><LessonCard {...l} level="advanced"/>)}
      </div>
    </section>

    <!-- Practice -->
    <section id="practice" class="mb-8">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-3 h-3 rounded-full bg-amber-500 flex-shrink-0"></div>
        <h2 class="font-display font-bold text-xl sm:text-2xl" style="color:#1c1008">Practice Tools</h2>
        <span class="badge badge-practice">{practice.length} modules</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        {practice.map(l=><LessonCard {...l} level="practice"/>)}
      </div>
    </section>

    <!-- CTA -->
    <div class="text-center mt-10">
      <a href="/practice" class="btn-primary inline-flex">🎹 Open Practice Tool</a>
    </div>
  </div>
</Layout>
