---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About Harmonium Halt — India's Free Online Harmonium Learning Platform"
  description="About Harmonium Halt — our mission to make harmonium education accessible to everyone in India and across the world. Free lessons, web harmonium, and expert content.">
  <div class="bg-white border-b" style="border-color:rgba(28,16,8,.08)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-2.5 breadcrumb"><a href="/">Home</a><span class="mx-1.5">›</span><span>About</span></div>
  </div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <div class="text-center mb-10 sm:mb-12">
      <div class="text-4xl sm:text-5xl mb-4">🎹</div>
      <h1 class="section-title text-3xl sm:text-4xl mb-4" style="color:#1c1008">About Harmonium Halt</h1>
      <p class="text-sm sm:text-lg max-w-2xl mx-auto leading-relaxed" style="color:rgba(28,16,8,.6);font-family:'Plus Jakarta Sans',sans-serif">Our mission: make quality harmonium education accessible to every person in India and across the world — completely free.</p>
    </div>
    <div class="rounded-2xl p-6 sm:p-8 mb-8 text-white" style="background:linear-gradient(135deg,#3d1a08,#1c1008)">
      <h2 class="font-display font-bold text-xl sm:text-2xl mb-4" style="color:#f0aa0e">Our Mission</h2>
      <p class="text-sm sm:text-base leading-relaxed mb-3" style="color:rgba(250,246,239,.8);font-family:'Plus Jakarta Sans',sans-serif">Harmonium is one of the most beloved instruments in India — heard in temples, homes, concert halls, and Bollywood studios. Yet quality harmonium education remains expensive and inaccessible for most people, particularly those in smaller cities and rural areas.</p>
      <p class="text-sm sm:text-base leading-relaxed" style="color:rgba(250,246,239,.8);font-family:'Plus Jakarta Sans',sans-serif">Harmonium Halt was created to change that. Every person with a love for music deserves access to expert harmonium education, regardless of where they live or their financial situation.</p>
    </div>
    <div class="grid sm:grid-cols-2 gap-4 mb-10">
      {[
        {icon:'🎹',title:'Interactive Web Harmonium',desc:'A fully functional harmonium in your browser using Web Audio API. Real sounds, all controls.'},
        {icon:'📖',title:'Structured Lessons',desc:'Complete curriculum from beginner (Sa Re Ga Ma) to advanced classical playing.'},
        {icon:'🔄',title:'Practice Tools',desc:'Daily riyaaz plans, alankar patterns, scale charts, and rhythm exercises.'},
        {icon:'📰',title:'Expert Blog',desc:'25+ in-depth articles on every aspect of harmonium learning.'},
        {icon:'📄',title:'Free Downloads',desc:'Printable PDF notes for scales, bhajans, alankars, and ragas.'},
        {icon:'🇮🇳',title:'Bilingual Content',desc:'Content in English and Hindi — accessible to learners across India.'},
      ].map(i=>(
        <div class="flex gap-3 p-4 sm:p-5 rounded-xl border bg-white" style="border-color:rgba(28,16,8,.08)">
          <div class="text-2xl flex-shrink-0">{i.icon}</div>
          <div>
            <h3 class="font-bold text-sm mb-1" style="color:#1c1008;font-family:'Plus Jakarta Sans',sans-serif">{i.title}</h3>
            <p class="text-xs sm:text-sm leading-relaxed" style="color:rgba(28,16,8,.6);font-family:'Plus Jakarta Sans',sans-serif">{i.desc}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center p-6 sm:p-8 rounded-2xl" style="background:#fdf9f0;border:1px solid rgba(212,146,10,.2)">
      <h2 class="font-display font-bold text-xl sm:text-2xl mb-3" style="color:#1c1008">Get in Touch</h2>
      <p class="text-sm mb-5" style="color:rgba(28,16,8,.6);font-family:'Plus Jakarta Sans',sans-serif">Questions, suggestions, or want to collaborate? We'd love to hear from you.</p>
      <a href="/contact" class="btn-primary inline-flex">Contact Us →</a>
    </div>
  </div>
</Layout>
